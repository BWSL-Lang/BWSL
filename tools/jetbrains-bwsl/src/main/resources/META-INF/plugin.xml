<idea-plugin>
    <id>com.bwsl.jetbrains-plugin</id>
    <name>BWSL Language</name>
    <version>1.0.0</version>
    <vendor>BWSL</vendor>

    <description>
        Syntax highlighting for the BWSL shader language (.bwsl files).
        Highlights keywords, type names, numbers, strings, and comments.
        Includes a color-settings page under Settings → Editor → Color Scheme → BWSL.
    </description>

    <idea-version since-build="241"/>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">

        <applicationService
            serviceImplementation="com.bwsl.plugin.BwslSettings"/>

        <applicationConfigurable
            instance="com.bwsl.plugin.BwslSettingsConfigurable"
            id="com.bwsl.plugin.settings"
            displayName="BWSL"/>


        <fileType
            name="BWSL"
            implementationClass="com.bwsl.plugin.BwslFileType"
            fieldName="INSTANCE"
            language="BWSL"
            extensions="bwsl"/>

        <lang.parserDefinition
            language="BWSL"
            implementationClass="com.bwsl.plugin.BwslParserDefinition"/>

        <lang.syntaxHighlighterFactory
            language="BWSL"
            implementationClass="com.bwsl.plugin.BwslSyntaxHighlighterFactory"/>

        <annotator
            language="BWSL"
            implementationClass="com.bwsl.plugin.BwslAnnotator"/>

        <colorSettingsPage
            implementation="com.bwsl.plugin.BwslColorSettingsPage"/>

    </extensions>
</idea-plugin>
