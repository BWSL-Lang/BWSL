# Build directory
build/

# Debug symbol bundles
*.dSYM/

# Object files
*.o

# Generated shader files
*.spv
*.metal
*.hlsl
*.glsl
*.gles

# Generated JSON files (IR dumps, internals)
*.internals.json
*_pass*.json

# macOS
.DS_Store

# Claude Code runtime files
.claude/

# Generated IDE/tooling files
compile_commands.json
c_cpp_properties.json

# IDE/Editor
.vscode/
.vs
.idea/
*.swp
*.swo
*~
.cache

# Temporary files
*.tmp
*.bak
__pycache__

# Test output files (keep .bwsl and .rcfg source files)
tests/output/
tests/equivalence/output/

# Golden files should be tracked (un-ignore)
!tests/golden/
!tests/golden/*.metal

# Fuzzer artifacts (grown corpus + raw crashes). Seeds live in tests/; verified
# minimized reproducers live in tests/fuzz_regressions/ and ARE tracked.
fuzz/corpus/
fuzz/crashes/
crash-*
