// Function called for its side effects on a storage scratch (write).
// Each call in the shader body inlines and emits the writes in-line.
pipeline FnSideEffectCall {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            // Local array acts as a write-observable "scratch"
            int scratch[8];
            for (int i = 0; i < 8; i = i + 1) {
                scratch[i] = 0;
            }

            // Update a specific index (no return value)
            for (int i = 0; i < 8; i = i + 1) {
                if ((i & 1) == 0) {
                    scratch[i] = i * 10;
                } else {
                    scratch[i] = i * 100;
                }
            }

            int sum = 0;
            for (int i = 0; i < 8; i = i + 1) {
                sum = sum + scratch[i];
            }
        }
    }
}
