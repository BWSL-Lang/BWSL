// Expressions with compile-time-foldable arithmetic. Backends
// should emit the folded result; the IR may keep the arithmetic
// or fold it. Either way no UB should trigger.
pipeline ConstFoldArith {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            // All compile-time constants
            int a = 2 + 3 * 4;              // 14
            int b = (10 - 5) * (8 + 2);     // 50
            int c = 100 / 4 + 2;            // 27
            int d = (1 << 3) | (1 << 5);    // 40
            int e = 0xFF ^ 0x0F;            // 0xF0 = 240

            float f = 1.5 + 2.5 * 3.0;      // 9.0
            float g = (10.0 - 2.5) / 3.0;   // 2.5
            float h = 0.5 * 4.0 - 1.0;      // 1.0

            // Mixed with runtime value
            int x = int(input.global_id.x);
            int mixed = x * 2 + 5 - 3;

            int total = a + b + c + d + e + int(f + g + h) + mixed;
        }
    }
}
