// Regression: unpack_snorm4x8 is registered as a stdlib intrinsic and lowers to OP_UNPACK_SNORM4X8.
pipeline IntrinsicUnpackSnorm4x8 {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            uint packed = 0x7F0040C0u ^ input.global_id.x;
            float4 unpacked = unpack_snorm4x8(packed);
            float total = unpacked.x + unpacked.y + unpacked.z + unpacked.w;
        }
    }
}
