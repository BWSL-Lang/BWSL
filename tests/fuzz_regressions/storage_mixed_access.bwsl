// Local struct array written through one access pattern and read
// through another. Mixing chained-member + dynamic-index read/write
// on the same base.
pipeline StorageMixedAccess {
    struct Item {
        float3 pos;
        float  mass;
    };

    pass "Compute" {
        compute "Main" [1, 1, 1] {
            Item items[4];

            // Initialise via index-then-member
            for (int i = 0; i < 4; i = i + 1) {
                items[i].pos = float3(float(i), float(i), float(i));
                items[i].mass = float(i) + 1.0;
            }

            // Overwrite specific slot's sub-field
            items[2].pos.x = 99.0;
            items[2].pos.yz = float2(88.0, 77.0);

            // Chained reads
            uint idx = input.global_id.x;
            int dyn = int(idx) & 3;
            float3 chosenPos = items[dyn].pos;
            float sum = chosenPos.x + chosenPos.y + chosenPos.z;
            float massTotal = 0.0;
            for (int i = 0; i < 4; i = i + 1) {
                massTotal = massTotal + items[i].mass;
            }
            float total = sum + massTotal;
        }
    }
}
