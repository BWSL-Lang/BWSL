// Function with multiple distinct return statements across different
// control-flow paths. Inlining must emit the guard-flag pattern
// (inlineReturnFlagReg) so later statements don't execute once a
// prior return fires.
pipeline FnMultiReturnPaths {
    classify :: (int x) -> int {
        if (x < 0) {
            return -1;
        }
        if (x == 0) {
            return 0;
        }
        if (x < 10) {
            return 1;
        }
        if (x < 100) {
            return 2;
        }
        return 3;
    }

    pass "Compute" {
        compute "Main" [1, 1, 1] {
            int a = classify(-5);
            int b = classify(0);
            int c = classify(7);
            int d = classify(42);
            int e = classify(9999);

            int total = a + b + c + d + e;
        }
    }
}
