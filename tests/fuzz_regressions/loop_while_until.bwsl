// Loops with conditional break and a single-iteration fake
// do-while via a bool guard. Tests the CFG's loop-merge +
// OpBranchConditional generation for interrupted loops.
pipeline LoopWhileUntil {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            int i = 0;
            int acc = 0;
            for (int k = 0; k < 100; k = k + 1) {
                if (acc > 50) break;
                if ((i & 1) == 0) {
                    acc = acc + i;
                }
                i = i + 1;
            }

            int j = 0;
            bool keepGoing = true;
            for (int m = 0; m < 1000; m = m + 1) {
                if (!keepGoing) break;
                j = j + 1;
                if (j >= 10) {
                    keepGoing = false;
                }
            }

            int result = acc + j;
        }
    }
}
