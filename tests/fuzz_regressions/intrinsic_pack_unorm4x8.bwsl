// Regression: pack_unorm4x8 is registered as a stdlib intrinsic and lowers to OP_PACK_UNORM4X8.
pipeline IntrinsicPackUnorm4x8 {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            float x = float(input.global_id.x & 255u) / 255.0;
            uint packed = pack_unorm4x8(float4(x, 0.25, 0.5, 1.0));
            uint total = packed ^ input.global_id.x;
        }
    }
}
