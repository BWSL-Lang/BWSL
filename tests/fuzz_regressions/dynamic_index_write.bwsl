// Dynamic vector write via runtime index. Goes through
// OP_VEC_INSERT_DYNAMIC / OpVectorInsertDynamic (fix #11 last session).
// Combined here with alternating reads and writes to stress SSA's
// handling of the composite-re-materialization pattern.
pipeline DynamicIndexWrite {
    pass "Compute" {
        compute "Main" [8, 1, 1] {
            uint idx = input.global_id.x;
            int pick = int(idx) & 3;
            float4 v = float4(1.0, 2.0, 3.0, 4.0);
            v[pick] = float(idx) * 0.5;
            float a = v[(pick + 1) & 3];
            v[(pick + 2) & 3] = a + 10.0;
            float b = v.x + v.y + v.z + v.w;
        }
    }
}
