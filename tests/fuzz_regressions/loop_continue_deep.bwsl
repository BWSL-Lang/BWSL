// `continue` (spelled `skip` in BWSL?) in nested loops. The
// continue must jump to the innermost loop's continue block.
pipeline LoopContinueDeep {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            int sum = 0;
            for (int i = 0; i < 10; i = i + 1) {
                if ((i & 1) == 0) {
                    continue;
                }
                for (int j = 0; j < 5; j = j + 1) {
                    if (j == i) {
                        continue;
                    }
                    if (i * j > 50) {
                        break;
                    }
                    sum = sum + i * j;
                }
            }

            int result = sum;
        }
    }
}
