// Chain of storage-buffer accesses modeled via a local array of
// structs. Tests the OP_STORAGE_FIELD / OP_STORAGE_INDEX ordering
// when simulated locally. The fuzz harness runs with no rcfg, so
// we use local-array semantics.
pipeline StorageIndexChain {
    struct Cell {
        float v;
        int i;
    };

    pass "Compute" {
        compute "Main" [1, 1, 1] {
            Cell cells[4];
            for (int k = 0; k < 4; k = k + 1) {
                cells[k].v = float(k) * 1.5;
                cells[k].i = k * 10;
            }

            int idx = int(input.global_id.x) & 3;

            // Chain patterns:
            //   cells[i].field
            //   cells[f(i)].field
            //   cells[i].field += expr
            float a = cells[idx].v;
            int b = cells[(idx + 1) & 3].i;
            cells[idx].v += 100.0;
            cells[idx].i = cells[idx].i * 2;

            float c = cells[0].v + cells[1].v + cells[2].v + cells[3].v;
            int d = cells[0].i + cells[1].i + cells[2].i + cells[3].i;

            float total = a + float(b) + c + float(d);
        }
    }
}
