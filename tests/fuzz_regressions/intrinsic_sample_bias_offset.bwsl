// Regression: sample_bias_offset lowers to implicit-LOD sampling with bias and offset operands.
pipeline IntrinsicSampleBiasOffset {
    resources {
        colorTex: texture2D
    }

    pass "Main" {
        use resources { colorTex }

        vertex {
            output.position = float4(0.0, 0.0, 0.0, 1.0);
            output.texcoord = float2(0.5, 0.5);
        }

        fragment {
            float4 c = sample_bias_offset(resources.colorTex, input.texcoord, 0.0, int2(0, 1));
            output.color = c;
        }
    }
}
