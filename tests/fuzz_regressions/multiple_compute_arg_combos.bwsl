// Compute shader using multiple arguments in unusual combinations:
// workgroup size in each dim, different index calculations, and
// combined with shared memory.
pipeline MultipleComputeArgCombos {
    pass "Compute" {
        compute "Main" [4, 4, 2] {
            shared float tile[32];

            uint3 gid = input.global_id;
            uint3 lid = input.local_id;
            uint local_idx = input.local_index;

            // Write initial from gid
            float seed = float(gid.x + gid.y * 4u + gid.z * 16u);
            if (local_idx < 32u) {
                tile[local_idx] = seed;
            }

            barrier();

            // Cross-read
            uint partner = (local_idx + 16u) & 31u;
            float val = tile[partner];

            // Combine
            float result = seed + val;
        }
    }
}
