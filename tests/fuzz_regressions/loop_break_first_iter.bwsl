// Captured 2026-04-20 as a pre-existing SSA bug. As of 2026-04-20
// (same day fix) SSA tracks which blocks the dominator-tree
// traversal actually visits; the post-rename cleanup fills every
// still-0xFFFF phi operand with a typed undef register and NOPs out
// unvisited (unreachable) blocks so the SPIR-V backend no longer
// trips over raw pre-SSA operand references.
pipeline LoopBreakFirstIter {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            int count = 0;
            for (int k = 0; k < 100; k = k + 1) {
                count = count + 1;
                break;
            }
            int result = count;

            // Also the "always-first-iter-break" pattern via if.
            int j = 0;
            for (int m = 0; m < 10; m = m + 1) {
                if (m == 0) {
                    break;
                }
                j = j + 100;
            }
        }
    }
}
