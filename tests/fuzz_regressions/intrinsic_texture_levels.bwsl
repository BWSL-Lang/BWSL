// Regression: texture_levels is registered as a stdlib intrinsic and lowers to OP_TEX_LEVELS.
pipeline IntrinsicTextureLevels {
    resources {
        colorTex: texture2D
    }

    pass "Main" {
        use resources { colorTex }

        vertex {
            float2[3] positions;
            positions[0] = float2(-1.0, -1.0);
            positions[1] = float2( 3.0, -1.0);
            positions[2] = float2(-1.0,  3.0);

            float2 p = positions[input.vertex_id];
            output.position = float4(p, 0.0, 1.0);
        }

        fragment {
            int levels = texture_levels(resources.colorTex);
            float mips = float(max(levels, 1));
            output.color = float4(1.0 / mips, 0.0, 0.0, 1.0);
        }
    }
}
