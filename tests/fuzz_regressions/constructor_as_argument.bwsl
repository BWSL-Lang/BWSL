// Vector/struct constructor as the argument to another function.
// Tests that the constructor's result register is correctly typed
// when consumed by a function parameter.
pipeline ConstructorAsArgument {
    struct Pt { float3 v; float w; };

    sumPt :: (Pt p) -> float {
        return p.v.x + p.v.y + p.v.z + p.w;
    }

    length3 :: (float3 v) -> float {
        return length(v);
    }

    pass "Compute" {
        compute "Main" [1, 1, 1] {
            // Construct struct inline as argument
            Pt tmp;
            tmp.v = float3(1.0, 2.0, 3.0);
            tmp.w = 4.0;
            float a = sumPt(tmp);

            // Vector constructor as argument
            float b = length3(float3(3.0, 4.0, 0.0));    // 5.0

            // Nested constructor
            float c = length3(float3(1.0, 2.0, 3.0) * 2.0);

            float total = a + b + c;
        }
    }
}
