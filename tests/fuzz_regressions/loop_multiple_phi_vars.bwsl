// Loop that updates many loop-carried variables (phi sources). SSA
// must generate one PHI per updated variable at the loop header,
// with operands from entry + latch.
pipeline LoopMultiplePhiVars {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            int a = 0; int b = 1; int c = 2; int d = 3;
            float x = 0.0; float y = 1.0; float z = 2.0;
            uint u = 5u;

            for (int i = 0; i < 10; i = i + 1) {
                a = a + 1;
                b = b * 2;
                c = c - 1;
                d = d + i;
                x = x + 0.5;
                y = y * 1.1;
                z = z - 0.25;
                u = u + 3u;
            }

            float total = float(a + b + c + d) + x + y + z + float(u);
        }
    }
}
