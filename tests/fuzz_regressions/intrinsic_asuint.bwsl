// Regression: asuint is registered as a stdlib intrinsic and lowers to OP_BITCAST.
pipeline IntrinsicAsuint {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            float x = float(input.global_id.x) + 1.0;
            uint scalar = asuint(x);
            uint3 vector = asuint(float3(x, x + 1.0, x + 2.0));
            uint total = scalar + vector.x + vector.y + vector.z;
        }
    }
}
