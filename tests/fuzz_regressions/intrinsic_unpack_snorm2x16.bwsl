// Regression: unpack_snorm2x16 is registered as a stdlib intrinsic and lowers to OP_UNPACK_SNORM2X16.
pipeline IntrinsicUnpackSnorm2x16 {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            uint packed = 0x4000C000u ^ input.global_id.x;
            float2 unpacked = unpack_snorm2x16(packed);
            float total = unpacked.x + unpacked.y;
        }
    }
}
