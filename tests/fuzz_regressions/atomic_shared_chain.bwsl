// Atomic operations against shared memory elements in a realistic
// reduce pattern. Exercises OP_ATOMIC_ADD with a shared-memory pointer.
pipeline AtomicSharedChain {
    pass "Compute" {
        compute "Main" [16, 1, 1] {
            shared int tally[1];

            uint idx = input.local_id.x;
            if (idx == 0u) {
                tally[0] = 0;
            }

            barrier();

            atomic_fetch_add(tally[0], int(idx));

            barrier();

            int finalCount = tally[0];
        }
    }
}
