// atomic_fetch_min / atomic_fetch_max / atomic_fetch_and /
// atomic_fetch_or / atomic_fetch_xor on shared memory. Each op
// routes to a different OpAtomic* SPIR-V instruction.
pipeline AtomicMinMaxOps {
    pass "Compute" {
        compute "Main" [8, 1, 1] {
            shared int[1] minVal;
            shared int[1] maxVal;
            shared int[1] andMask;
            shared int[1] orMask;

            uint idx = input.local_id.x;
            if (idx == 0u) {
                minVal[0] = 100;
                maxVal[0] = -100;
                andMask[0] = 0xFFFF;
                orMask[0] = 0;
            }

            barrier();

            int x = int(idx) * 7 - 20;
            atomic_fetch_min(minVal[0], x);
            atomic_fetch_max(maxVal[0], x);
            atomic_fetch_and(andMask[0], x & 0xFF);
            atomic_fetch_or(orMask[0], 1 << int(idx));

            barrier();

            int final = minVal[0] + maxVal[0] + andMask[0] + orMask[0];
        }
    }
}
