// Chained function calls passing intermediate results. Inlining
// must handle nested call sites without register collision and
// without exceeding MAX_INLINE_DEPTH.
pipeline DeeplyNestedFnCalls {
    inc :: (int x) -> int { return x + 1; }
    add :: (int a, int b) -> int { return a + b; }
    mul :: (int a, int b) -> int { return a * b; }
    combo :: (int x, int y) -> int { return mul(add(x, y), inc(y)); }

    pass "Compute" {
        compute "Main" [1, 1, 1] {
            int a = combo(3, 4);                    // depth 2
            int b = combo(combo(1, 2), combo(3, 4)); // depth 3
            int c = add(mul(inc(5), inc(6)), combo(2, 3));  // depth 3
            int d = inc(inc(inc(inc(inc(inc(inc(1))))))); // chain 7

            int total = a + b + c + d;
        }
    }
}
