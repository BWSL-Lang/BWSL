// Regression: unpack_unorm4x8 is registered as a stdlib intrinsic and lowers to OP_UNPACK_UNORM4X8.
pipeline IntrinsicUnpackUnorm4x8 {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            uint packed = 0xFF804020u ^ input.global_id.x;
            float4 unpacked = unpack_unorm4x8(packed);
            float total = unpacked.x + unpacked.y + unpacked.z + unpacked.w;
        }
    }
}
