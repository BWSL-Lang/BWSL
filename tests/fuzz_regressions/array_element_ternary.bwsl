// Ternary selecting between array elements. Each branch returns a
// different element of the same array.
pipeline ArrayElementTernary {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            int arr[4];
            arr[0] = 10;
            arr[1] = 20;
            arr[2] = 30;
            arr[3] = 40;

            int idx = int(input.global_id.x) & 3;
            bool cond = (idx < 2);

            // Ternary selecting between two array elements
            int v = cond ? arr[0] : arr[3];

            // Ternary where condition is indexed
            int v2 = (arr[idx] > 20) ? 99 : -99;

            int total = v + v2;
        }
    }
}
