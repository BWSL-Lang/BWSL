// Regression: pack_snorm2x16 is registered as a stdlib intrinsic and lowers to OP_PACK_SNORM2X16.
pipeline IntrinsicPackSnorm2x16 {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            float x = float(input.global_id.x & 127u) / 127.0;
            uint packed = pack_snorm2x16(float2(-x, x));
            uint total = packed ^ input.global_id.x;
        }
    }
}
