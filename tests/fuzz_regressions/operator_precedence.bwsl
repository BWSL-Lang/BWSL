// Operator precedence stress: mixing arithmetic, bitwise, comparison,
// logical, and ternary without parentheses. Parser produces a BinaryOp
// tree that should evaluate to the expected precedence order per
// GLSL/C rules.
pipeline OperatorPrecedence {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            int a = 1 + 2 * 3 - 4 / 2;         // 1 + 6 - 2 = 5
            int b = 10 % 3 + 1 << 2;           // (10%3 + 1) << 2 = 2 << 2 = 8
            int c = 0xFF & 0x0F | 0xF0;        // 0x0F | 0xF0 = 0xFF
            int d = 5 > 3 ? 1 : 2;             // 1
            bool e = 1 + 2 == 3 && 4 > 2;      // true
            int f = (a + b) * (c - d);         // explicit grouping

            float g = 1.5 + 2.5 * 3.0 - 0.5;   // 1.5 + 7.5 - 0.5 = 8.5
            float h = 10.0 - 2.0 * 3.0 / 1.5;  // 10 - 4 = 6.0
            bool i = 1.0 < 2.0 == true;

            int total = a + b + c + d + f + (e ? 100 : 0) + (i ? 1000 : 0);
            float ftotal = g + h;
        }
    }
}
