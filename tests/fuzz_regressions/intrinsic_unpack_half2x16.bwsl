// Regression: unpack_half2x16 is registered as a stdlib intrinsic and lowers to OP_UNPACK_HALF2X16.
pipeline IntrinsicUnpackHalf2x16 {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            uint packed = 0x3C003800u ^ input.global_id.x;
            float2 unpacked = unpack_half2x16(packed);
            float total = unpacked.x + unpacked.y;
        }
    }
}
