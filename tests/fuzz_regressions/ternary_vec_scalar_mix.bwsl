// Ternary with vector on one side and vector-of-different-width on
// the other; also mixing with scalar-broadcast construction. OpSelect
// requires both operands to share type, so the lowering must splat /
// convert where needed.
pipeline TernaryVecScalarMix {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            uint idx = input.global_id.x;
            bool pick = (idx & 1u) == 0u;

            // Vector ternary, both vec3
            float3 a = pick ? float3(1.0, 2.0, 3.0) : float3(-1.0, -2.0, -3.0);

            // Scalar ternary used as a component
            float s = pick ? 10.0 : 20.0;
            float3 b = float3(s, s, s);

            // Nested ternary, all vec3
            float3 c = pick
                ? (a * 2.0)
                : (a + float3(0.5, 0.5, 0.5));

            // Scalar-float ternary
            float v = pick ? 1.5 : 2.5;

            float3 sum = a + b + c;
            float total = sum.x + sum.y + sum.z + v;
        }
    }
}
