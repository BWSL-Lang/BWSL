// Regression: rcp is registered as a stdlib intrinsic and lowers to reciprocal division.
pipeline IntrinsicRcp {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            float x = float(input.global_id.x) + 2.0;
            float scalar = rcp(x);
            float3 vector = rcp(float3(x, x + 1.0, x + 2.0));
            float total = scalar + vector.x + vector.y + vector.z;
        }
    }
}
