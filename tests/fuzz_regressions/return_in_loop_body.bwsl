// User fn with a return deep inside a for loop body's else branch.
// Guard flag + loop continue-block must thread correctly.
pipeline ReturnInLoopBody {
    findWhen :: (int n) -> int {
        for (int i = 0; i < 100; i = i + 1) {
            if (i * i > n) {
                return i;
            } else {
                if ((i & 1) == 0) {
                    continue;
                }
            }
        }
        return -1;
    }

    pass "Compute" {
        compute "Main" [1, 1, 1] {
            int a = findWhen(10);
            int b = findWhen(99);
            int c = findWhen(10000);
            int total = a + b + c;
        }
    }
}
