// Nested ifs where each branch defines a variable. After merge, the
// phi has contributions from every path. 4 branches total.
pipeline NestedIfMergePhi {
    pass "Compute" {
        compute "Main" [1, 1, 1] {
            int idx = int(input.global_id.x);
            int result;

            if (idx < 0) {
                if (idx < -10) {
                    result = -2;
                } else {
                    result = -1;
                }
            } else {
                if (idx > 10) {
                    result = 2;
                } else {
                    result = 1;
                }
            }

            // Now use result after the nested-if merge
            int r = result * 100;

            // Another level
            float fresult;
            if (idx > 0) {
                if ((idx & 1) == 0) {
                    if (idx > 5) {
                        fresult = 1.0;
                    } else {
                        fresult = 2.0;
                    }
                } else {
                    fresult = 3.0;
                }
            } else {
                fresult = 4.0;
            }

            float fr = fresult + float(r);
        }
    }
}
