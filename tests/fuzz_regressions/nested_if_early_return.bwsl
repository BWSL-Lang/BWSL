// User function with early return from a deeply nested if/for. The
// inlining path has to emit the early-return guard flag across
// multiple loop levels — previously a source of phi/merge errors.
pipeline NestedIfEarlyReturn {
    classify :: (int v) -> int {
        int acc = 0;
        for (int i = 0; i < 8; i = i + 1) {
            for (int j = 0; j < 8; j = j + 1) {
                if (i == v && j == v) {
                    return acc + 1000;
                }
                if (i > v) {
                    if ((j & 1) == 0) {
                        acc = acc + 2;
                        continue;
                    } else {
                        return acc * 10;
                    }
                }
                acc = acc + 1;
            }
            if (acc > 50) {
                return acc;
            }
        }
        return acc;
    }

    pass "Compute" {
        compute "Main" [1, 1, 1] {
            int x = classify(3);
        }
    }
}
