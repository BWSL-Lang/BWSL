// Test: enum switch with variant labels via member-access syntax.
// Regression for: "switch case values must be compile-time literals" fired
// when a MEMBER_ACCESS AST node was used as a case label (e.g. `Side.Left`
// instead of `Side::Left`).

pipeline EnumSwitchMemberAccess {

    resources {
        output: buffer<float>
    }
    enum Side { Left, Right, Center }

    resolve :: (s: Side) -> float {
        switch (s) {
            case Side::Left:   return 1.0;
            case Side::Right:  return 2.0;
            case Side::Center: return 3.0;
        }
        return 0.0;
    }

    pass "Compute" {
        use resources { output }
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            Side s = (idx == 0u) ? Side::Left :
                     (idx == 1u) ? Side::Right :
                                   Side::Center;
            float v = resolve(s);
            resources.output[idx] = v + float(idx) * 0.01;
        }
    }
}
