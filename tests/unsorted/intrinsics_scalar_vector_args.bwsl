// Test: Intrinsics with mixed scalar/vector argument shapes
// Tests: clamp/min/max with scalar bounds on vector values, lerp with
//        scalar and vector t, smoothstep with scalar edges and vector x,
//        pow with vector exponent

pipeline IntrinsicsScalarVectorArgs {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            float3 p = attributes.position;

            // Scalar bounds broadcast over a vector value
            float3 c1 = clamp(p, 0.0, 1.0);
            float3 c2 = clamp(p, float3(0.0, 0.0, 0.0), float3(1.0, 1.0, 1.0));
            float3 m1 = max(p, 0.5);
            float3 m2 = min(p, float3(0.5, 0.5, 0.5));

            // lerp with scalar and with vector interpolant
            float3 l1 = lerp(p, c1, 0.5);
            float3 l2 = lerp(p, c1, float3(0.2, 0.5, 0.8));

            // smoothstep with scalar edges over scalar and vector x
            float s1 = smoothstep(0.0, 1.0, p.x);
            float3 s2 = smoothstep(0.0, 1.0, p);
            float3 s3 = smoothstep(float3(0.0, 0.0, 0.0), float3(1.0, 1.0, 1.0), p);

            float3 pw = pow(abs(p), float3(2.0, 2.0, 2.0));

            output.position = float4(c2 + m1 + m2 + l1 + l2 + s2 + s3 + pw, s1);
        }
    }
}
