pipeline control_switch_complex {
    pass "Main" {
        vertex {
            int x = 2;
            float4 color = float4(0.0, 0.0, 0.0, 1.0);

            switch (x) {
                case 0:
                    color.r = 1.0;
                    break;
                case 1:
                case 2:
                    color.g = 1.0;
                    break;
                case 3:
                    color.b = 1.0;
                    break;
                default:
                    color.a = 0.5;
                    break;
            }

            // Test fall-through if the language supports it (assuming it doesn't for now)
            int y = 1;
            float val = 0.0;
            switch(y) {
                case 1:
                    val = 1.0;
                case 2:
                    val = 2.0;
                    break;
                default:
                    val = 3.0;
            }


            if (color.g == 1.0 && val == 2.0) {
                 output.position = float4(1.0, 1.0, 1.0, 1.0);
            } else {
                 output.position = float4(0.0, 0.0, 0.0, 0.0);
            }
        }
        fragment {
            output.color = float4(1.0, 1.0, 1.0, 1.0);
        }
    }
}
