// Test: Array sizes resolved from compile-time constant names
// Tests: const-sized struct member arrays, loops bounded by the same constants
// NOTE: docs/language.md says array sizes can be "constant names that resolve
// at compile time", but the parser only accepts that for struct fields
// (bwsl_parser_soa_types.inl). Local and shared array declarations require a
// number literal (bwsl_parser_soa_statements.inl). If that gap is closed,
// extend this test to use KERNEL_SIZE / TILE for the local and shared arrays.

pipeline ArraysConstSized {
    const int KERNEL_SIZE = 5;
    const int BONE_COUNT = 4;
    const int TILE = 16;

    // NOTE: deliberately a scalar array: struct fields that are arrays of
    // vectors or matrices (float4 bones[N], mat4 bones[N]) currently emit
    // invalid SPIR-V when the element is read back (mistyped registers in
    // struct-array lowering). Upgrade this to mat4 bones[BONE_COUNT] once
    // that bug is fixed.
    struct Skin {
        float boneWeights[BONE_COUNT];
    }

    attributes {
        position: float3
    }

    resources {
        results: buffer<float>
    }

    pass "Graphics" {
        use attributes { position }

        vertex {
            // Struct member array sized by a pipeline constant
            Skin skin;
            for (int b = 0; b < BONE_COUNT; b++) {
                skin.boneWeights[b] = float(b) * 0.25;
            }
            float4 p = float4(attributes.position * skin.boneWeights[1], 1.0);

            // Local array: literal size, loop bounded by the constant
            float taps[5];
            for (int i = 0; i < KERNEL_SIZE; i++) {
                taps[i] = float(i) * 0.25;
            }
            float sum = 0.0;
            for (int i = 0; i < KERNEL_SIZE; i++) {
                sum = sum + taps[i];
            }

            output.position = p * sum;
        }

        fragment {
            output.color = float4(1.0, 0.0, 1.0, 1.0);
        }
    }

    pass "Compute" {
        use resources { results }

        compute "Blur" [16, 1, 1] {
            // Shared array: literal size (const names not yet accepted here)
            shared float tile[16];

            uint3 gid = input.global_id;
            uint lane = input.local_index;

            tile[lane] = float(gid.x) * 0.5;
            barrier();
            resources.results[gid.x] = tile[(lane + 1u) % 16u];
        }
    }
}
