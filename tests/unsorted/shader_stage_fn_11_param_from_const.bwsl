// Test: Parameter using pipeline const
pipeline ShaderStageFnParamFromConst {
    attributes {
        position: float3
    }

    const float baseScale = 2.0;

    vertexFuncWithScale :: (float scale) -> vertex_function {
        vertex {
            output.position = float4(scale, scale * 0.5, 0.0, 1.0);
        }
    }

    pass "ParamFromConst" {
        use attributes { position }
        vertex = vertexFuncWithScale(baseScale)
        fragment {
            output.color = float4(1.0, 0.5, 0.0, 1.0);
        }
    }
}
