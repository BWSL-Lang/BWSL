// Test: Ternary selecting same function with different params
pipeline ShaderStageFnTernaryDiffParams {
    attributes {
        position: float3
    }

    const bool useRedVertex = true;

    vertexFuncWithScale :: (float scale) -> vertex_function {
        vertex {
            output.position = float4(scale, scale * 0.5, 0.0, 1.0);
        }
    }

    pass "TernaryDifferentParams" {
        use attributes { position }
        vertex = useRedVertex ? vertexFuncWithScale(3.0) : vertexFuncWithScale(1.0)
        fragment {
            output.color = float4(0.0, 0.0, 1.0, 1.0);
        }
    }
}
