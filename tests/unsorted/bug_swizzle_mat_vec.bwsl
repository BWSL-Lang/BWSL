// BUG: .xyz swizzle on mat*vec result generates invalid OpCompositeExtract
// Expected: Valid SPIR-V extracting xyz from float4
// Actual: "Result type (OpTypeFloat) does not match the type that results from indexing into the composite (OpTypeVector)"

pipeline BugSwizzleMatVec {

    resources {
        viewMatrix: mat4
        projectionMatrix: mat4
        modelMatrix: mat4
        viewProjMatrix: mat4
        lightViewProjMatrix: mat4
        particles: buffer<Particle>
    }

attributes {
    position: float3
}

pass "Test" {
        use resources { viewMatrix, projectionMatrix, modelMatrix, viewProjMatrix, lightViewProjMatrix, particles }
    use attributes { position }

    vertex {
        mat4 modelMatrix = resources.modelMatrix;
        mat4 viewProjMatrix = resources.projectionMatrix * resources.viewMatrix;

        // This causes the SPIR-V validation error
        float3 worldPos = (modelMatrix * float4(attributes.position, 1.0)).xyz;

        output.position = viewProjMatrix * float4(worldPos, 1.0);
    }

    fragment {
        output.color = float4(1.0);
    }
}

}
