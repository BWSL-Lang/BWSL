// Test: Early return patterns
// Tests: return if (condition), multiple return paths, return from nested scopes

pipeline EarlyReturn {
    attributes {
        position: float3
        texcoord: float2
    }

    // Simple early return
    absValue :: (float x) -> float {
        return -x if (x < 0.0);
        return x;
    }

    // Multiple early returns
    classifyValue :: (float x) -> int {
        return -1 if (x < -1.0);
        return 0 if (x < 0.0);
        return 1 if (x < 1.0);
        return 2;
    }

    // Early return with computation
    safeDivide :: (float a, float b) -> float {
        return 0.0 if (abs(b) < 0.0001);
        return a / b;
    }

    // Early return in loop
    findFirst :: (int target) -> int {
        for (int i = 0; i < 10; i = i + 1) {
            return i if (i * i > target);
        }
        return -1;
    }

    // Early return from nested if
    computeRegion :: (float2 p) -> int {
        if (p.x > 0.0) {
            return 1 if (p.y > 0.0);
            return 2;
        }
        return 3 if (p.y > 0.0);
        return 4;
    }

    // Multiple conditions in return
    selectChannel :: (float3 color, int channel) -> float {
        return color.r if (channel == 0);
        return color.g if (channel == 1);
        return color.b if (channel == 2);
        return 0.0;
    }

    // Early return with complex condition
    isInBounds :: (float2 p, float2 minB, float2 maxB) -> bool {
        return false if (p.x < minB.x || p.x > maxB.x);
        return false if (p.y < minB.y || p.y > maxB.y);
        return true;
    }

    // Nested function calls with early returns
    processValue :: (float x) -> float {
        float abs_x = absValue(x);
        return 0.0 if (abs_x < 0.1);

        int cls = classifyValue(x);
        return -1.0 if (cls < 0);

        return safeDivide(abs_x, float(cls + 1));
    }

    // Early return in switch-like pattern
    getWeight :: (int index) -> float {
        return 1.0 if (index == 0);
        return 0.5 if (index == 1);
        return 0.25 if (index == 2);
        return 0.125 if (index == 3);
        return 0.0;
    }

    // Return from deeply nested structure
    searchGrid :: (float target) -> int {
        for (int i = 0; i < 4; i = i + 1) {
            for (int j = 0; j < 4; j = j + 1) {
                float value = float(i * 4 + j) / 16.0;
                return i * 10 + j if (abs(value - target) < 0.05);
            }
        }
        return -1;
    }

    // Boolean early returns
    allPositive :: (float3 v) -> bool {
        return false if (v.x <= 0.0);
        return false if (v.y <= 0.0);
        return false if (v.z <= 0.0);
        return true;
    }

    // Early return with side effects (accumulator)
    countUntil :: (int limit) -> int {
        int count = 0;
        for (int i = 0; i < 20; i = i + 1) {
            count = count + 1;
            return count if (count >= limit);
        }
        return count;
    }

    pass "Main" {
        use attributes { position, texcoord }

        vertex {
            float3 pos = attributes.position;
            float2 uv = attributes.texcoord;

            // Test various early return patterns
            float absX = absValue(pos.x - 0.5);
            int classification = classifyValue(pos.y);
            float divided = safeDivide(pos.x, pos.y);
            int firstFound = findFirst(int(uv.x * 100.0));
            int region = computeRegion(uv - 0.5);
            float channel = selectChannel(pos, int(uv.x * 3.0));
            bool inBounds = isInBounds(uv, float2(0.2), float2(0.8));
            float processed = processValue(pos.x);
            float weight = getWeight(int(uv.y * 4.0));
            int gridPos = searchGrid(uv.x);
            bool allPos = allPositive(pos + 0.5);
            int counted = countUntil(int(uv.x * 10.0) + 1);

            // Combine results
            float4 finalPos = float4(pos, 1.0);
            finalPos.x = finalPos.x + absX * 0.01;

            output.position = finalPos;
            output.uv = uv;
            output.classification = float(classification);
            output.region = float(region);
            output.inBounds = inBounds ? 1.0 : 0.0;
            output.weight = weight;
            output.counted = float(counted);
        }

        fragment {
            float2 uv = input.uv;
            float classification = input.classification;
            float region = input.region;
            float inBounds = input.inBounds;
            float weight = input.weight;
            float counted = input.counted;

            // Visualize results
            float3 color = float3(0.5);

            // Color by region
            int reg = int(region);
            if (reg == 1) {
                color = float3(1.0, 0.3, 0.3);
            } else if (reg == 2) {
                color = float3(0.3, 1.0, 0.3);
            } else if (reg == 3) {
                color = float3(0.3, 0.3, 1.0);
            } else {
                color = float3(1.0, 1.0, 0.3);
            }

            // Darken if out of bounds
            color = color * (0.3 + 0.7 * inBounds);

            // Apply weight
            color = color * weight;

            // Add classification influence
            color = color + float3(classification * 0.1, 0.0, 0.0);

            output.color = float4(saturate(color), 1.0);
        }
    }
}
