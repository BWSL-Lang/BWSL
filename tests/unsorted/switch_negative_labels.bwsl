// Test: Negative switch case labels
// Tests: single negative labels, negative values in multi-value case arms
// Regression test for: `case -3:` rejected as a non-compile-time literal

pipeline SwitchNegativeLabels {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            int code = int(attributes.position.x);
            float r = 0.0;
            switch (code) {
                case -3: r = 1.0;
                case 2, -7: r = 2.0;
                case 0: r = 3.0;
                default: r = 4.0;
            }
            output.position = float4(attributes.position, r);
        }
    }
}
