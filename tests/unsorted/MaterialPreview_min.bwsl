// ============================================
// Material Preview Pipeline - Bug isolation test 7
// Add PBR function call - MINIMAL reproducer to narrow down
// ============================================
pipeline MaterialPreview {

    resources {
        viewMatrix: mat4
        projMatrix: mat4
        cameraPosition: float3
        material: GPUMaterialData
        previewLight: PreviewLight
        materialTextureArray: texture2DArray
        materialSampler: sampler
    }

import Color
import PBR

attributes {
    position: float3
    normal: float3
    texcoord: float2
}

struct GPUMaterialData {
    int albedoTextureIndex
    int normalTextureIndex
    int roughnessTextureIndex
    int metallicTextureIndex
    int aoTextureIndex
    int heightTextureIndex
    int emissiveTextureIndex
    uint flags

    float4 baseColor
    float4 emissiveColor

    float roughnessValue
    float metallicValue
    float aoValue
    float heightScale

    float2 uvScale
    float2 uvOffset
}

struct PreviewLight {
    float3 position
    float intensity
    float3 color
    float _pad
}

pass "PreviewPass" {
        use resources { viewMatrix, projMatrix, cameraPosition, material, previewLight, materialTextureArray, materialSampler }
    use attributes { position, normal, texcoord }

    vertex {
        float3 pos = attributes.position;
        float4 worldPos = float4(pos, 1.0);
        output.worldPos = worldPos.xyz;
        output.normal = attributes.normal;
        output.texCoord = attributes.texcoord;
        output.position = resources.projMatrix * resources.viewMatrix * worldPos;
    }

    fragment {
        GPUMaterialData mat = resources.material;

        float2 uv = input.texCoord * mat.uvScale + mat.uvOffset;

        float3 albedo = Color::sRGBToLinear(mat.baseColor.rgb);
        float3 N = normalize(input.normal);
        float3 V = float3(0.0, 0.0, 1.0);

        PreviewLight light = resources.previewLight;

        float3 L = normalize(light.position - input.worldPos);
        float3 radiance = light.color * light.intensity;

        PBR::PBRMaterial pbrMat;
        pbrMat.albedo = albedo;
        pbrMat.roughness = mat.roughnessValue;
        pbrMat.metallic = mat.metallicValue;
        pbrMat.ao = mat.aoValue;

        // THE TRIGGER: PBR function call
        float3 Lo = PBR::calculateDirectLighting(pbrMat, N, V, L, radiance);

        // Emissive - BUG shows up here after the function call
        float3 emissive = mat.emissiveColor.rgb * mat.emissiveColor.a;

        float3 finalColor = albedo + emissive + Lo;
        output.color = float4(finalColor, 1.0);
    }
}

}
