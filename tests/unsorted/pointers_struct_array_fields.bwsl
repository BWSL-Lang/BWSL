// Test: Pointers to aggregate members
// Tests: address-of a struct field, address-of an array element,
//        writes through such pointers, pointer reassignment inside a loop

pipeline PointersStructArrayFields {
    attributes {
        position: float3
    }

    struct S {
        float a;
        float b;
    }

    pass "Main" {
        use attributes { position }

        vertex {
            S s;
            s.a = 1.0;
            s.b = 2.0;

            float[4] arr;
            arr[0] = 5.0;
            arr[1] = 6.0;

            // Pointer to an array element: read-modify-write
            float^ pa = ^arr[1];
            pa^ = pa^ + 1.0;

            // Pointer to a struct field
            float^ pf = ^s.a;
            pf^ = 10.0;

            // Pointer retargeted inside a loop body
            float x = 1.0;
            float y = 100.0;
            float^ p = ^x;
            for (int i = 0; i < 2; i = i + 1) {
                p^ = p^ + 1.0;
                p = ^y;
            }

            // s.a == 10, arr[1] == 7, x == 2, y == 101
            output.position = float4(attributes.position, s.a + arr[1] + x + y);
        }
    }
}
