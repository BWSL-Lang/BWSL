// Test: Both vertex and fragment with parameters
pipeline ShaderStageFnBothWithParams {
    attributes {
        position: float3
    }

    vertexFuncWithScale :: (float scale) -> vertex_function {
        vertex {
            output.position = float4(scale, scale * 0.5, 0.0, 1.0);
        }
    }

    fragmentFuncWithColor :: (float r, float g, float b) -> fragment_function {
        fragment {
            output.color = float4(r, g, b, 1.0);
        }
    }

    pass "BothWithParams" {
        use attributes { position }
        vertex = vertexFuncWithScale(1.5)
        fragment = fragmentFuncWithColor(0.3, 0.7, 0.4)
    }
}
