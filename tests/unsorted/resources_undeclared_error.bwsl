// Test: resources not declared in the pipeline resources block are rejected.

pipeline ResourcesUndeclaredError {
    attributes {
        position: float3
    }

    resources {
        viewProj: mat4
    }

    pass "Main" {
        use attributes { position }
        use resources { viewProj }

        vertex {
            float4 p = resources.legacyMatrix * float4(attributes.position, 1.0);
            output.position = resources.viewProj * p;
        }

        fragment {
            output.color = float4(1.0);
        }
    }
}
