// Test: Explicit-gradient sampling, comparison sampling, and gather
// Tests: sample_grad, sample_cmp, gather (implicit and explicit sampler forms)
// sample_cmp uses a dedicated shadow texture: comparison usage marks the
// texture as a depth texture during cross-compilation, so it must not be
// mixed with regular color sampling on the same resource.

pipeline TextureSampleGradCmpGather {
    attributes {
        position: float3
        texcoord: float2
    }

    resources {
        colorTex: texture2D
        shadowTex: texture2D
        shadowTexExplicit: texture2D
        colorSampler: sampler
        cmpSampler: sampler
    }

    pass "Main" {
        use attributes { position, texcoord }
        use resources { colorTex, shadowTex, shadowTexExplicit, colorSampler, cmpSampler }

        vertex {
            output.position = float4(attributes.position, 1.0);
            output.texcoord = attributes.texcoord;
        }

        fragment {
            float2 uv = input.texcoord;

            // Explicit gradient sampling (implicit sampler)
            float2 gradX = ddx(uv);
            float2 gradY = ddy(uv);
            float4 graded = sample_grad(resources.colorTex, uv, gradX, gradY);

            // Explicit gradient sampling with explicit sampler
            float4 gradedExplicit = sample_grad(resources.colorTex, resources.colorSampler, uv, gradX, gradY);

            // Comparison (shadow) sampling against a reference depth,
            // implicit and explicit sampler forms
            float refDepth = 0.5;
            float4 shadow = sample_cmp(resources.shadowTex, uv, refDepth);
            float4 shadowExplicit = sample_cmp(resources.shadowTexExplicit, resources.cmpSampler, uv, refDepth + 0.1);

            // Gather a single component from the 2x2 footprint
            float4 reds = gather(resources.colorTex, uv, 0);
            float4 greens = gather(resources.colorTex, uv, 1);

            float3 rgb = graded.rgb + gradedExplicit.rgb * 0.25;
            float occlusion = shadow.x * shadowExplicit.x * (reds.x + greens.y) * 0.5;
            output.color = float4(rgb * occlusion, 1.0);
        }
    }
}
