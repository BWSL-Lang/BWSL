// Test: return (or discard) inside a switch case in a loop body
// Regression for known issue 7: LowerSwitch emits each case's jump to the
// switch merge unconditionally, so a case body ending in OP_RET is followed
// by a dead OP_JUMP. CFGBuilder::FindLeaders did not start a new block after
// OP_RET/OP_DISCARD, so the dead jump shared a block with the return and the
// SPIR-V backend emitted OpBranch directly after OpReturn ("Branch must
// appear in a block"). Broke for every loop form combined with a
// return-bearing case plus any statement after the switch.

pipeline LoopSwitchCaseReturn {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            // Scenario 1: for loop, return in a middle case, statement after
            // the switch (the original repro shape).
            float acc = 0.0;
            for (int i = 0; i < 8; i = i + 1) {
                switch (i) {
                    case 0: { acc = acc + 1.0; }
                    case 1: { output.position = float4(acc); return; }
                    default: { acc = acc + 0.5; }
                }
                if (acc > 4.0) { break; }
            }

            // Scenario 2: while loop with return in the default arm.
            float acc2 = 0.0;
            int j = 0;
            while (j < 8) {
                switch (j) {
                    case 0: { acc2 = acc2 + 1.0; }
                    default: { output.position = float4(acc2); return; }
                }
                j = j + 1;
            }

            // Scenario 3: range-for and counted loop forms.
            for (k in 0..8) {
                switch (k) {
                    case 2: { output.position = float4(acc); return; }
                    default: { acc = acc + 0.5; }
                }
                acc = acc + 0.125;
            }
            loop (4) {
                switch (int(acc)) {
                    case 3: { output.position = float4(acc); return; }
                    default: { acc = acc + 0.5; }
                }
                if (acc > 6.0) { break; }
            }

            output.position = float4(attributes.position * (acc + acc2), 1.0);
        }

        fragment {
            // Scenario 4: discard hits the same OP_DISCARD leader gap.
            float acc = 0.0;
            for (int i = 0; i < 4; i = i + 1) {
                switch (i) {
                    case 0: { acc = acc + 1.0; }
                    case 1: { discard; }
                    default: { acc = acc + 0.5; }
                }
                if (acc > 2.0) { break; }
            }

            // Control: return-bearing case outside any loop still works.
            switch (int(acc)) {
                case 0: { acc = acc + 1.0; }
                case 1: { output.color = float4(acc); return; }
                default: { acc = acc + 0.5; }
            }

            output.color = float4(acc, acc, 1.0, 1.0);
        }
    }
}
