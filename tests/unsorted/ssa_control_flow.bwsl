// Test: SSA with control flow
// Tests: phi nodes at join points, if/else merging

pipeline SSAControlFlow {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            float cond_val = 0.5;

            // Simple if - phi at join
            float result1 = 0.0;
            if (cond_val > 0.3) {
                result1 = 1.0;
            }
            // result1 is either 0.0 or 1.0 - requires phi

            // If-else - phi with two predecessors
            float result2 = 0.0;
            if (cond_val > 0.5) {
                result2 = 1.0;
            } else {
                result2 = -1.0;
            }
            // result2 is either 1.0 or -1.0

            // Nested if - multiple phis
            float result3 = 0.0;
            if (cond_val > 0.25) {
                if (cond_val > 0.5) {
                    result3 = 2.0;
                } else {
                    result3 = 1.0;
                }
            } else {
                result3 = 0.0;
            }

            // If-else if-else chain
            float result4 = 0.0;
            if (cond_val < 0.25) {
                result4 = 0.0;
            } else if (cond_val < 0.5) {
                result4 = 1.0;
            } else if (cond_val < 0.75) {
                result4 = 2.0;
            } else {
                result4 = 3.0;
            }

            // Variable modified in both branches
            float x = 1.0;
            if (cond_val > 0.5) {
                x = x + 1.0;
            } else {
                x = x - 1.0;
            }
            float after_if = x;  // Either 2.0 or 0.0

            // Multiple variables modified
            float a = 1.0;
            float b = 2.0;
            if (cond_val > 0.5) {
                a = 10.0;
                b = 20.0;
            } else {
                a = -10.0;
                b = -20.0;
            }
            float sum_ab = a + b;

            // Vector modified in branches
            float3 color = float3(0.0);
            if (cond_val > 0.5) {
                color = float3(1.0, 0.0, 0.0);  // Red
            } else {
                color = float3(0.0, 0.0, 1.0);  // Blue
            }
            float3 final_color = color;

            // Modification before and after if
            float seq = 0.0;
            seq = seq + 1.0;      // seq = 1.0
            if (cond_val > 0.5) {
                seq = seq + 10.0;  // seq = 11.0
            }
            seq = seq + 100.0;     // seq = 101.0 or 111.0
            float final_seq = seq;

            // Deeply nested
            float deep = 0.0;
            if (cond_val > 0.1) {
                deep = 1.0;
                if (cond_val > 0.3) {
                    deep = 2.0;
                    if (cond_val > 0.5) {
                        deep = 3.0;
                        if (cond_val > 0.7) {
                            deep = 4.0;
                        }
                    }
                }
            }
            float final_deep = deep;

            output.position = float4(attributes.position, 1.0);
        }

        fragment {
            output.color = float4(1.0, 1.0, 1.0, 1.0);
        }
    }
}
