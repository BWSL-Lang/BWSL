// Test: Inlined function returns should guard and skip fallthrough
// Tests: early return in inlined function does not execute later statements

pipeline InlineReturnJump {
    attributes {
        position: float3
    }

    chooseValue :: (float v) -> float {
        if (v > 0.0) {
            return 1.0;
        }
        return 2.0;
    }

    pass "Main" {
        use attributes { position }

        vertex {
            float v = chooseValue(1.0);
            output.position = float4(attributes.position, 1.0);
            output.position.x = v;
        }
    }
}
