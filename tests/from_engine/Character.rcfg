# Character Pipeline - Skinned PBR Rendering
pipeline Character

# ============= TARGETS =============
target SceneColor RGBA16Float viewport
target VelocityBuffer RG16Float viewport
target SceneDepth Depth32Float viewport

# ============= UNIFORMS =============
# Transform matrices (view/projection only - model comes from buffer)
# Note: indices 0-9 reserved for vertex attribute buffers
uniform viewMatrix mat4 10 vertex fragment
uniform projectionMatrix mat4 11 vertex
uniform previousViewProjMatrix mat4 12 vertex
uniform lightViewProjMatrix mat4 13 vertex

# TAA
uniform taaJitter float2 14 vertex

# ============= STORAGE BUFFERS =============
# Per-draw metadata buffer (indexed by instance_id)
buffer drawMetadata DrawMetadata 15 readonly vertex

# Transform buffer (indexed by metadata.transformIndex)
buffer transformBuffer mat4 16 readonly vertex

# Bone matrices buffer for GPU skinning (indexed by bone index)
# Contains: skinning matrix per bone (66 bones max)
buffer boneMatrices mat4 17 readonly vertex

# Material buffer (indexed by metadata.materialIndex)
buffer materialBuffer GPUMaterialData 18 readonly fragment

# Camera (kept for view calculations)
# Note: Avoid slot 0 (Metal internal), slots 21+ cause SPIR-V bug
uniform cameraPosition float3 1 fragment
uniform ambientColor float3 2 fragment

# PBR textures (legacy individual bindings)
uniform albedoTexture sampler2D 5 fragment
uniform normalMap sampler2D 6 fragment
uniform roughnessMap sampler2D 7 fragment
uniform metallicMap sampler2D 8 fragment
uniform aoMap sampler2D 9 fragment
uniform textureSampler sampler 10 fragment

# Material texture array (bindless access via materialIndex)
uniform materialTextureArray sampler2DArray 11 fragment
uniform materialSampler sampler 12 fragment

# ============= LIGHTING =============
# Light count
uniform lightCount uint 13 fragment

# Light buffer (SoA structure from Aurora)
buffer lightBuffer LightSourcesSoA 19 readonly fragment

# ============= SHADOWS =============
# Shadow data buffer (CSM cascades + settings)
buffer shadowData ShadowData 20 readonly fragment

# Shadow map array texture (CSM layers)
uniform shadowMapArray sampler2DArray 14 fragment
uniform shadowSampler sampler 15 fragment

# Point light shadows (cubemaps for first 2 point lights)
uniform pointShadowCube0 samplerCube 16 fragment
uniform pointShadowCube1 samplerCube 17 fragment
uniform pointShadowFarPlane float 3 fragment

# ============= PASSES =============
pass ShadowPass
  type geometry
  depth SceneDepth clear 1.0 store
  depends none

pass OpaquePass
  type geometry
  color SceneColor clear 0.0 0.0 0.0 1.0 store
  color VelocityBuffer clear 0.0 0.0 0.0 0.0 store
  depth SceneDepth clear 1.0 store
  depends ShadowPass
