# UI Pipeline - User Interface Rendering
pipeline UI

# ============= TARGETS =============
# Note: UI renders to the swapchain which uses BGRA8Unorm_sRGB
target UIColor BGRA8Unorm_sRGB viewport

# ============= UNIFORMS =============
# Screen parameters (vertex)
# Note: indices 0-9 reserved for vertex attribute buffers
uniform screenSize float2 10 vertex

# Fragment uniforms - properly numbered
uniform atlasSize float2 0 fragment
uniform opacity float 1 fragment
uniform time float 2 fragment

# SDF text parameters
uniform isSDFText int 3 fragment
uniform outlineWidth float 4 fragment
uniform outlineColor float4 5 fragment
uniform shadowEnabled int 6 fragment
uniform shadowOffset float2 7 fragment
uniform shadowOpacity float 8 fragment
uniform shadowColor float4 9 fragment

# Nine-slice parameters
uniform elementSize float2 10 fragment
uniform sliceBorders float4 11 fragment
uniform sourceSlice float4 12 fragment

# Rounded rect parameters
uniform rectSize float2 13 fragment
uniform cornerRadii float4 14 fragment
uniform borderWidth float 15 fragment
uniform borderColor float4 16 fragment

# Progress bar parameters
uniform progress float 17 fragment
uniform backgroundColor float4 18 fragment
uniform fillColor float4 19 fragment
uniform useGradient int 20 fragment
uniform gradientStart float4 21 fragment
uniform gradientEnd float4 22 fragment
uniform shineEnabled int 23 fragment

# Color picker parameters
# hue is only used by ColorSVPass (no conflict with rectSize)
uniform hue float 24 fragment
# baseColor/previewColor at slot 25, rectSize (slot 13) reused from RoundedRect
uniform baseColor float4 25 fragment
uniform previewColor float4 25 fragment

# Textures - binding indices must be < 16 for Metal sampler limits
uniform atlasTexture sampler2D 1 fragment
uniform sdfAtlas sampler2D 2 fragment
uniform atlasSampler sampler 0 fragment

# MSDF Text parameters
# Note: fontAtlas must be at low binding so SPIRV-Cross generates sampler index < 16
uniform fontAtlas sampler2D 3 fragment
uniform pxRange float 28 fragment

# Textured UI Pass parameters (for render target preview)
uniform texture sampler2D 4 fragment
uniform textureSampler sampler 1 fragment

# Focused Window Pass parameters (reuse bindings < 32 to avoid backend slot limit)
uniform windowSize float2 30 fragment
uniform shadowOffsetY float 31 fragment
uniform shadowBlur float 29 fragment
uniform borderColor1 float4 26 fragment
uniform borderColor2 float4 27 fragment
uniform shadowPadding float2 7 fragment
uniform rotationSpeed float 8 fragment

# ============= PASSES =============
pass UIPass
  type geometry
  color UIColor clear 0.0 0.0 0.0 0.0 store
  depends none

pass SDFTextPass
  type geometry
  color UIColor load store
  depends UIPass

pass MSDFTextPass
  type geometry
  color UIColor load store
  depends SDFTextPass

pass NineSlicePass
  type geometry
  color UIColor load store
  depends MSDFTextPass

pass RoundedRectPass
  type geometry
  color UIColor load store
  depends NineSlicePass

pass TexturedPass
  type geometry
  color UIColor load store
  depends RoundedRectPass

pass ProgressBarPass
  type geometry
  color UIColor load store
  depends TexturedPass

pass ColorSVPass
  type geometry
  color UIColor load store
  depends ProgressBarPass

pass ColorHuePass
  type geometry
  color UIColor load store
  depends ColorSVPass

pass ColorAlphaPass
  type geometry
  color UIColor load store
  depends ColorHuePass

pass CheckerboardPass
  type geometry
  color UIColor load store
  depends ColorAlphaPass

pass ColorPreviewPass
  type geometry
  color UIColor load store
  depends CheckerboardPass

pass FocusedWindowPass
  type geometry
  color UIColor load store
  depends ColorPreviewPass
