// ============================================
// Post-Processing Pipeline - TAA, Bloom, Tone Mapping
// ============================================
pipeline PostProcess {

    resources {
        screenSize: float2
        sourceSize: float2
        currentFrameBuffer: texture2D
        velocityBuffer: texture2D
        historyBuffer: texture2D
        sceneColor: texture2D
        sourceTexture: texture2D
        previousMipTexture: texture2D
        bloomTexture: texture2D
        bloomThreshold: float
        bloomKnee: float
        bloomIntensity: float
        hdrBuffer: texture2D
        exposure: float
        tonemapOperator: int
        whitePoint: float
        vignetteEnabled: int
        vignetteIntensity: float
        filmGrainEnabled: int
        filmGrainIntensity: float
        time: float
        inputTexture: texture2D
        pointSampler: sampler
        linearSampler: sampler
    }

import Math
import Color

// ============================================
// No Vertex Attributes - Fullscreen Triangle
// ============================================
attributes {
    // Fullscreen passes generate vertices procedurally
}

// ============================================
// Shared Fullscreen Vertex Shader
// ============================================

fullscreenVertex :: () -> vertex_function {
     vertex {
        // Generate fullscreen triangle (3 vertices cover entire screen)
        float2[3] positions;
        positions[0] = float2(-1.0, -1.0);
        positions[1] = float2( 3.0, -1.0);
        positions[2] = float2(-1.0,  3.0);

        output.position = float4(positions[input.vertex_id], 0.0, 1.0);
        output.uv = (positions[input.vertex_id] + 1.0) * 0.5;
        output.uv.y = 1.0 - output.uv.y;  // Flip Y for Metal coordinate system
    }
}

// ============================================
// Temporal Anti-Aliasing (TAA) Pass
// ============================================
pass "TAAPass" {
        use resources { screenSize, sourceSize, currentFrameBuffer, velocityBuffer, historyBuffer, sceneColor, sourceTexture, previousMipTexture, bloomTexture, bloomThreshold, bloomKnee, bloomIntensity, hdrBuffer, exposure, tonemapOperator, whitePoint, vignetteEnabled, vignetteIntensity, filmGrainEnabled, filmGrainIntensity, time, inputTexture, pointSampler, linearSampler }
    
    vertex = fullscreenVertex()
    
    fragment {
        // Current frame color
        float3 currentColor = sample(resources.currentFrameBuffer, resources.pointSampler, input.uv).rgb;
        
        // Velocity for reprojection
        float2 velocity = sample(resources.velocityBuffer, resources.pointSampler, input.uv).rg;
        
        // Reprojected UV for history lookup
        float2 historyUV = input.uv - velocity;
        
        // Sample history buffer
        float3 historyColor = sample(resources.historyBuffer, resources.linearSampler, historyUV).rgb;
        
        // Neighborhood clamping to reduce ghosting
        float3 nearMin = float3(999999.0);
        float3 nearMax = float3(-999999.0);
        
        // 3x3 neighborhood sampling
        float2 texelSize = 1.0 / resources.screenSize;
        for (x in -1..=1) {
            for (y in -1..=1) {
                float2 offset = float2(x, y) * texelSize;
                float3 neighborColor = sample(resources.currentFrameBuffer, resources.pointSampler, input.uv + offset).rgb;
                nearMin = min(nearMin, neighborColor);
                nearMax = max(nearMax, neighborColor);
            }
        }
        
        // Clip history color to neighborhood bounds (variance clipping)
        float3 clampedHistory = clamp(historyColor, nearMin, nearMax);
        
        // Blend factor - increase for more temporal stability, decrease for less ghosting
        float blendFactor = 0.9;
        
        // Reduce blend factor for high velocity (fast motion)
        float velocityMagnitude = length(velocity * resources.screenSize);
        blendFactor *= saturate(1.0 - velocityMagnitude * 0.1);
        
        // Reduce blend factor for disoccluded pixels (outside screen bounds)
        if (historyUV.x < 0.0 || historyUV.x > 1.0 || historyUV.y < 0.0 || historyUV.y > 1.0) {
            blendFactor = 0.0;
        }
        
        // Final blend
        float3 finalColor = lerp(currentColor, clampedHistory, blendFactor);
        
        output.color = float4(finalColor, 1.0);
    }
}

// ============================================
// Bloom Extraction Pass (Bright pixels)
// ============================================
pass "BloomExtract" {
        use resources { screenSize, sourceSize, currentFrameBuffer, velocityBuffer, historyBuffer, sceneColor, sourceTexture, previousMipTexture, bloomTexture, bloomThreshold, bloomKnee, bloomIntensity, hdrBuffer, exposure, tonemapOperator, whitePoint, vignetteEnabled, vignetteIntensity, filmGrainEnabled, filmGrainIntensity, time, inputTexture, pointSampler, linearSampler }
    
    vertex = fullscreenVertex()
    
    fragment {
        float3 color = sample(resources.sceneColor, resources.linearSampler, input.uv).rgb;
        
        // Calculate luminance
        float luminance = dot(color, float3(0.2126, 0.7152, 0.0722));
        
        // Extract bright pixels above threshold
        float brightness = max(0.0, luminance - resources.bloomThreshold);
        
        // Soft knee for smooth transition
        float knee = resources.bloomThreshold * resources.bloomKnee;
        float soft = brightness - resources.bloomThreshold + knee;
        soft = clamp(soft, 0.0, 2.0 * knee);
        soft = soft * soft / (4.0 * knee + 0.00001);
        float contribution = max(soft, brightness) / max(luminance, 0.00001);
        
        output.color = float4(color * contribution, 1.0);
    }
}

// ============================================
// Bloom Downsample Pass (Gaussian Blur)
// ============================================
pass "BloomDownsample" {
        use resources { screenSize, sourceSize, currentFrameBuffer, velocityBuffer, historyBuffer, sceneColor, sourceTexture, previousMipTexture, bloomTexture, bloomThreshold, bloomKnee, bloomIntensity, hdrBuffer, exposure, tonemapOperator, whitePoint, vignetteEnabled, vignetteIntensity, filmGrainEnabled, filmGrainIntensity, time, inputTexture, pointSampler, linearSampler }
    
    vertex = fullscreenVertex()
    
    fragment {
        float2 texelSize = 1.0 / resources.sourceSize;
        
        // 13-tap downsampling filter (Karis average for first pass)
        float3 color = float3(0.0);
        
        // Center samples
        float3 a = sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2(-2.0, -2.0)).rgb;
        float3 b = sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2( 0.0, -2.0)).rgb;
        float3 c = sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2( 2.0, -2.0)).rgb;
        float3 d = sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2(-2.0,  0.0)).rgb;
        float3 e = sample(resources.sourceTexture, resources.linearSampler, input.uv).rgb;
        float3 f = sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2( 2.0,  0.0)).rgb;
        float3 g = sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2(-2.0,  2.0)).rgb;
        float3 h = sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2( 0.0,  2.0)).rgb;
        float3 i = sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2( 2.0,  2.0)).rgb;
        
        // Additional samples for smoother result
        float3 j = sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2(-1.0, -1.0)).rgb;
        float3 k = sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2( 1.0, -1.0)).rgb;
        float3 l = sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2(-1.0,  1.0)).rgb;
        float3 m = sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2( 1.0,  1.0)).rgb;
        
        // Weighted average (optimized 13-tap filter)
        color = e * 0.125;
        color += (a + c + g + i) * 0.03125;
        color += (b + d + f + h) * 0.0625;
        color += (j + k + l + m) * 0.125;
        
        output.color = float4(color, 1.0);
    }
}

// ============================================
// Bloom Upsample Pass (Tent Filter)
// ============================================
pass "BloomUpsample" {
        use resources { screenSize, sourceSize, currentFrameBuffer, velocityBuffer, historyBuffer, sceneColor, sourceTexture, previousMipTexture, bloomTexture, bloomThreshold, bloomKnee, bloomIntensity, hdrBuffer, exposure, tonemapOperator, whitePoint, vignetteEnabled, vignetteIntensity, filmGrainEnabled, filmGrainIntensity, time, inputTexture, pointSampler, linearSampler }
    
    vertex = fullscreenVertex()
    
    fragment {
        float2 texelSize = 1.0 / resources.sourceSize;
        
        // 9-tap tent filter for upsampling
        float3 color = float3(0.0);
        
        color += sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2(-1.0, -1.0)).rgb * 1.0;
        color += sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2( 0.0, -1.0)).rgb * 2.0;
        color += sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2( 1.0, -1.0)).rgb * 1.0;
        color += sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2(-1.0,  0.0)).rgb * 2.0;
        color += sample(resources.sourceTexture, resources.linearSampler, input.uv).rgb * 4.0;
        color += sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2( 1.0,  0.0)).rgb * 2.0;
        color += sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2(-1.0,  1.0)).rgb * 1.0;
        color += sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2( 0.0,  1.0)).rgb * 2.0;
        color += sample(resources.sourceTexture, resources.linearSampler, input.uv + texelSize * float2( 1.0,  1.0)).rgb * 1.0;
        
        color /= 16.0;
        
        // Add to previous mip level
        float3 previousMip = sample(resources.previousMipTexture, resources.linearSampler, input.uv).rgb;
        color += previousMip;
        
        output.color = float4(color, 1.0);
    }
}

// ============================================
// Bloom Composite Pass
// ============================================
pass "BloomPass" {
        use resources { screenSize, sourceSize, currentFrameBuffer, velocityBuffer, historyBuffer, sceneColor, sourceTexture, previousMipTexture, bloomTexture, bloomThreshold, bloomKnee, bloomIntensity, hdrBuffer, exposure, tonemapOperator, whitePoint, vignetteEnabled, vignetteIntensity, filmGrainEnabled, filmGrainIntensity, time, inputTexture, pointSampler, linearSampler }
    
    vertex = fullscreenVertex()
    
    fragment {
        float3 sceneColor = sample(resources.sceneColor, resources.linearSampler, input.uv).rgb;
        float3 bloomColor = sample(resources.bloomTexture, resources.linearSampler, input.uv).rgb;
        
        // Combine scene with bloom
        float3 finalColor = sceneColor + bloomColor * resources.bloomIntensity;
        
        output.color = float4(finalColor, 1.0);
    }
}

// ============================================
// Tone Mapping Pass (HDR to LDR)
// ============================================
pass "ToneMappingPass" {
        use resources { screenSize, sourceSize, currentFrameBuffer, velocityBuffer, historyBuffer, sceneColor, sourceTexture, previousMipTexture, bloomTexture, bloomThreshold, bloomKnee, bloomIntensity, hdrBuffer, exposure, tonemapOperator, whitePoint, vignetteEnabled, vignetteIntensity, filmGrainEnabled, filmGrainIntensity, time, inputTexture, pointSampler, linearSampler }
    
    vertex = fullscreenVertex()
    
    fragment {
        // Sample HDR color with bloom
        float3 hdrColor = sample(resources.hdrBuffer, resources.linearSampler, input.uv).rgb;
        float3 bloomColor = sample(resources.bloomTexture, resources.linearSampler, input.uv).rgb;
        
        hdrColor += bloomColor * resources.bloomIntensity;
        
        // Apply exposure
        hdrColor *= resources.exposure;
        
        // Tone mapping operator selection
        float3 ldrColor;
        
        switch (resources.tonemapOperator) {
            case 0: {
                // ACES Filmic
                ldrColor = Color::ACESFilm(hdrColor);
                break;
            }
            case 1: {
                // Reinhard
                ldrColor = Color::reinhardToneMap(hdrColor);
                break;
            }
            case 2: {
                // Reinhard Extended
                ldrColor = Color::reinhardExtendedToneMap(hdrColor, resources.whitePoint);
                break;
            }
            case 3: {
                // Uncharted 2
                ldrColor = uncharted2Tonemap(hdrColor);
                break;
            }
            default: {
                ldrColor = Color::ACESFilm(hdrColor);
                break;
            }
        }
        
        // Gamma correction (linear to sRGB)
        ldrColor = Color::linearToSRGB(ldrColor);
        
        // Optional vignette
        if (resources.vignetteEnabled) {
            float2 centered = input.uv - 0.5;
            float vignette = 1.0 - dot(centered, centered) * resources.vignetteIntensity;
            vignette = saturate(vignette);
            vignette = smoothstep(0.0, 1.0, vignette);
            ldrColor *= vignette;
        }
        
        // Optional film grain
        if (resources.filmGrainEnabled) {
            float noise = fract(sin(dot(input.uv * resources.time, float2(12.9898, 78.233))) * 43758.5453);
            ldrColor += (noise - 0.5) * resources.filmGrainIntensity;
        }
        
        output.color = float4(ldrColor, 1.0);
    }
}

// ============================================
// FXAA Pass (Fast Approximate Anti-Aliasing)
// ============================================
pass "FXAAPass" {
        use resources { screenSize, sourceSize, currentFrameBuffer, velocityBuffer, historyBuffer, sceneColor, sourceTexture, previousMipTexture, bloomTexture, bloomThreshold, bloomKnee, bloomIntensity, hdrBuffer, exposure, tonemapOperator, whitePoint, vignetteEnabled, vignetteIntensity, filmGrainEnabled, filmGrainIntensity, time, inputTexture, pointSampler, linearSampler }
    
    vertex = fullscreenVertex()
    
    fragment {
        float2 texelSize = 1.0 / resources.screenSize;
        
        // Sample luminance at current and neighboring pixels
        float3 rgbM = sample(resources.inputTexture, resources.linearSampler, input.uv).rgb;
        float3 rgbNW = sample(resources.inputTexture, resources.linearSampler, input.uv + texelSize * float2(-1.0, -1.0)).rgb;
        float3 rgbNE = sample(resources.inputTexture, resources.linearSampler, input.uv + texelSize * float2( 1.0, -1.0)).rgb;
        float3 rgbSW = sample(resources.inputTexture, resources.linearSampler, input.uv + texelSize * float2(-1.0,  1.0)).rgb;
        float3 rgbSE = sample(resources.inputTexture, resources.linearSampler, input.uv + texelSize * float2( 1.0,  1.0)).rgb;
        
        // Compute luminance
        float3 luma = float3(0.299, 0.587, 0.114);
        float lumaNW = dot(rgbNW, luma);
        float lumaNE = dot(rgbNE, luma);
        float lumaSW = dot(rgbSW, luma);
        float lumaSE = dot(rgbSE, luma);
        float lumaM = dot(rgbM, luma);
        
        // Find min/max luma
        float lumaMin = min(lumaM, min(min(lumaNW, lumaNE), min(lumaSW, lumaSE)));
        float lumaMax = max(lumaM, max(max(lumaNW, lumaNE), max(lumaSW, lumaSE)));
        
        // Compute edge direction
        float2 dir;
        dir.x = -((lumaNW + lumaNE) - (lumaSW + lumaSE));
        dir.y = ((lumaNW + lumaSW) - (lumaNE + lumaSE));
        
        float dirReduce = max((lumaNW + lumaNE + lumaSW + lumaSE) * 0.25 * 0.25, 0.0078125);
        float rcpDirMin = 1.0 / (min(abs(dir.x), abs(dir.y)) + dirReduce);
        
        dir = min(float2(8.0), max(float2(-8.0), dir * rcpDirMin)) * texelSize;
        
        // Sample along edge
        float3 rgbA = 0.5 * (
            sample(resources.inputTexture, resources.linearSampler, input.uv + dir * (1.0/3.0 - 0.5)).rgb +
            sample(resources.inputTexture, resources.linearSampler, input.uv + dir * (2.0/3.0 - 0.5)).rgb
        );
        
        float3 rgbB = rgbA * 0.5 + 0.25 * (
            sample(resources.inputTexture, resources.linearSampler, input.uv + dir * -0.5).rgb +
            sample(resources.inputTexture, resources.linearSampler, input.uv + dir *  0.5).rgb
        );
        
        float lumaB = dot(rgbB, luma);
        
        // Choose result
        float3 finalColor;
        if (lumaB < lumaMin || lumaB > lumaMax) {
            finalColor = rgbA;
        } else {
            finalColor = rgbB;
        }
        
        output.color = float4(finalColor, 1.0);
    }
}

// ============================================
// Helper Functions
// ============================================

uncharted2Tonemap :: (float3 x) -> float3 {
    const float A = 0.15;  // Shoulder strength
    const float B = 0.50;  // Linear strength
    const float C = 0.10;  // Linear angle
    const float D = 0.20;  // Toe strength
    const float E = 0.02;  // Toe numerator
    const float F = 0.30;  // Toe denominator
    
    return ((x * (A * x + C * B) + D * E) / (x * (A * x + B) + D * F)) - E / F;
}

