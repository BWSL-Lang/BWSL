// ============================================
// UI Pipeline - User Interface Rendering
// ============================================
pipeline UI {

import Math

// ============================================
// Vertex Attributes
// ============================================
attributes {
    position: float3
    texcoord: float2
    color: float4
}

// ============================================
// Main UI Pass
// ============================================
pass "UIPass" {
    use attributes { position, texcoord, color }

    vertex {
        // Create orthographic projection based on screen size
        mat4 orthoProjection = mat4(
            float4(2.0 / resources.screenSize.x, 0.0, 0.0, 0.0),
            float4(0.0, 2.0 / resources.screenSize.y, 0.0, 0.0),
            float4(0.0, 0.0, 1.0, 0.0),
            float4(-1.0, -1.0, 0.0, 1.0)
        );

        output.position = orthoProjection * float4(attributes.position, 1.0);
        output.texCoord = attributes.texcoord;
        output.color = attributes.color;
    }

    fragment {
        float4 finalColor = input.color;
        finalColor.a *= resources.opacity;
        if (finalColor.a < 0.01) { discard; }
        output.color = finalColor;
    }
}

// ============================================
// SDF Text Pass (Signed Distance Field)
// ============================================
pass "SDFTextPass" {
    use attributes { position, texcoord, color }

    vertex {
        mat4 orthoProjection = mat4(
            float4(2.0 / resources.screenSize.x, 0.0, 0.0, 0.0),
            float4(0.0, 2.0 / resources.screenSize.y, 0.0, 0.0),
            float4(0.0, 0.0, 1.0, 0.0),
            float4(-1.0, -1.0, 0.0, 1.0)
        );

        output.position = orthoProjection * float4(attributes.position, 1.0);
        output.texCoord = attributes.texcoord;
        output.color = attributes.color;
    }

    fragment {
        // Sample SDF atlas
        float sdfDist = sample(resources.sdfAtlas, resources.atlasSampler, input.texCoord).r;

        // Calculate smoothing based on screen-space derivatives
        float smoothing = fwidth(sdfDist);

        // Standard SDF rendering
        float alpha = smoothstep(0.5 - smoothing, 0.5 + smoothing, sdfDist);

        // Optional outline
        float3 finalColor = input.color.rgb;
        if (resources.outlineWidth > 0.0) {
            float outlineEdge = 0.5 - resources.outlineWidth;
            float outlineAlpha = smoothstep(outlineEdge - smoothing, outlineEdge + smoothing, sdfDist);
            float3 outlineColor = resources.outlineColor.rgb;

            // Blend outline and fill (select: false_val, true_val, condition)
            float blendFactor = select(0.0, 1.0, sdfDist >= 0.5);
            finalColor = lerp(outlineColor, input.color.rgb, blendFactor);
            alpha = max(alpha, outlineAlpha);
        }

        // Optional shadow/drop shadow
        if (resources.shadowEnabled) {
            float2 shadowOffset = resources.shadowOffset / resources.atlasSize;
            float shadowDist = sample(resources.sdfAtlas, resources.atlasSampler, input.texCoord - shadowOffset).r;
            float shadowAlpha = smoothstep(0.5 - smoothing * 2.0, 0.5 + smoothing, shadowDist);
            shadowAlpha *= resources.shadowOpacity;

            // Composite shadow under text
            float3 shadowColor = resources.shadowColor.rgb;
            float compositeAlpha = alpha + shadowAlpha * (1.0 - alpha);
            finalColor = lerp(shadowColor * shadowAlpha, finalColor, alpha / max(compositeAlpha, 0.001));
            alpha = compositeAlpha;
        }

        output.color = float4(finalColor, alpha * input.color.a * resources.opacity);
    }
}

// ============================================
// MSDF Text Pass (Multi-channel Signed Distance Field)
// For high-quality text rendering with msdf-atlas-gen generated atlases
// ============================================
pass "MSDFTextPass" {
    use attributes { position, texcoord, color }

    vertex {
        // Y-up orthographic projection (matches UIPass for consistent coordinates)
        mat4 orthoProjection = mat4(
            float4(2.0 / resources.screenSize.x, 0.0, 0.0, 0.0),
            float4(0.0, 2.0 / resources.screenSize.y, 0.0, 0.0),
            float4(0.0, 0.0, 1.0, 0.0),
            float4(-1.0, -1.0, 0.0, 1.0)
        );

        output.position = orthoProjection * float4(attributes.position, 1.0);
        output.texCoord = attributes.texcoord;
        output.color = attributes.color;
    }

    fragment {
        // Sample MSDF atlas (RGB channels contain distance field data)
        float3 msd = sample(resources.fontAtlas, resources.atlasSampler, input.texCoord).rgb;

        // Calculate median of the three channels (MSDF technique)
        float sd = max(min(msd.r, msd.g), min(max(msd.r, msd.g), msd.b));

        // Calculate screen-space distance for proper anti-aliasing
        // pxRange is the distance field range in pixels used during atlas generation
        float screenPxDistance = resources.pxRange * (sd - 0.5);
        float opacity = clamp(screenPxDistance + 0.5, 0.0, 1.0);

        // Apply text color with calculated opacity
        float4 textColor = input.color;
        textColor.a *= opacity * resources.opacity;

        if (textColor.a < 0.01) {
            discard;
        }

        output.color = textColor;
    }
}

// ============================================
// Nine-Slice UI Pass
// ============================================
pass "NineSlicePass" {
    use attributes { position, texcoord, color }

    vertex {
        mat4 orthoProjection = mat4(
            float4(2.0 / resources.screenSize.x, 0.0, 0.0, 0.0),
            float4(0.0, 2.0 / resources.screenSize.y, 0.0, 0.0),
            float4(0.0, 0.0, 1.0, 0.0),
            float4(-1.0, -1.0, 0.0, 1.0)
        );

        output.position = orthoProjection * float4(attributes.position, 1.0);
        output.texCoord = attributes.texcoord;
        output.color = attributes.color;
    }

    fragment {
        // Simplified nine-slice - just sample texture
        float4 texColor = sample(resources.atlasTexture, resources.atlasSampler, input.texCoord);
        output.color = texColor * input.color;
    }
}

// ============================================
// Rounded Rectangle Pass (Procedural)
// ============================================
pass "RoundedRectPass" {
    use attributes { position, texcoord, color }

    vertex {
        mat4 orthoProjection = mat4(
            float4(2.0 / resources.screenSize.x, 0.0, 0.0, 0.0),
            float4(0.0, 2.0 / resources.screenSize.y, 0.0, 0.0),
            float4(0.0, 0.0, 1.0, 0.0),
            float4(-1.0, -1.0, 0.0, 1.0)
        );

        output.position = orthoProjection * float4(attributes.position, 1.0);
        output.texCoord = attributes.texcoord;
        output.color = attributes.color;
        output.localPos = attributes.position.xy;
    }

    fragment {
        float2 size = resources.rectSize;
        float4 radii = resources.cornerRadii;  // Per-corner radii: TL, TR, BL, BR

        // Convert UV to local coordinates
        float2 pos = input.texCoord * size;

        // Calculate SDF for rounded rectangle
        float2 halfSize = size * 0.5;
        float2 centered = pos - halfSize;

        // Determine which corner we're closest to
        float radius;
        if (centered.x < 0.0 && centered.y < 0.0) {
            radius = radii.x;  // Top-left
        } else if (centered.x >= 0.0 && centered.y < 0.0) {
            radius = radii.y;  // Top-right
        } else if (centered.x < 0.0 && centered.y >= 0.0) {
            radius = radii.z;  // Bottom-left
        } else {
            radius = radii.w;  // Bottom-right
        }

        // SDF calculation
        float2 q = abs(centered) - halfSize + radius;
        float dist = min(max(q.x, q.y), 0.0) + length(max(q, 0.0)) - radius;

        // Anti-aliased edge
        float smoothing = fwidth(dist);
        float alpha = 1.0 - smoothstep(-smoothing, smoothing, dist);

        // Optional border
        float4 finalColor = input.color;
        if (resources.borderWidth > 0.0) {
            float borderDist = abs(dist) - resources.borderWidth;
            float borderAlpha = 1.0 - smoothstep(-smoothing, smoothing, borderDist);

            if (dist > -resources.borderWidth) {
                finalColor = lerp(finalColor, resources.borderColor, borderAlpha);
            }
        }

        finalColor.a *= alpha * resources.opacity;

        if (finalColor.a < 0.01) {
            discard;
        }

        output.color = finalColor;
    }
}

// ============================================
// Textured UI Pass
// For rendering render targets, thumbnails, and other textures in UI
// ============================================
pass "TexturedPass" {
    use attributes { position, texcoord, color }

    vertex {
        mat4 orthoProjection = mat4(
            float4(2.0 / resources.screenSize.x, 0.0, 0.0, 0.0),
            float4(0.0, 2.0 / resources.screenSize.y, 0.0, 0.0),
            float4(0.0, 0.0, 1.0, 0.0),
            float4(-1.0, -1.0, 0.0, 1.0)
        );

        output.position = orthoProjection * float4(attributes.position, 1.0);
        output.texCoord = attributes.texcoord;
        output.color = attributes.color;
    }

    fragment {
        // Sample the texture (bound at slot 0)
        float4 texColor = sample(resources.texture, resources.textureSampler, input.texCoord);
        
        // Apply tint color (vertex color)
        float4 finalColor = texColor * input.color;
        
        // Apply global opacity
        finalColor.a *= resources.opacity;
        
        // Discard fully transparent pixels
        if (finalColor.a < 0.01) {
            discard;
        }
        
        output.color = finalColor;
    }
}

// ============================================
// Progress Bar Pass
// ============================================
pass "ProgressBarPass" {
    use attributes { position, texcoord, color }

    vertex {
        mat4 orthoProjection = mat4(
            float4(2.0 / resources.screenSize.x, 0.0, 0.0, 0.0),
            float4(0.0, 2.0 / resources.screenSize.y, 0.0, 0.0),
            float4(0.0, 0.0, 1.0, 0.0),
            float4(-1.0, -1.0, 0.0, 1.0)
        );

        output.position = orthoProjection * float4(attributes.position, 1.0);
        output.texCoord = attributes.texcoord;
        output.color = attributes.color;
    }

    fragment {
        float progress = resources.progress;  // 0.0 to 1.0
        float2 uv = input.texCoord;

        // Background color or fill color based on progress
        float4 finalColor = resources.backgroundColor;
        if (uv.x <= progress) {
            finalColor = resources.fillColor;
        }

        output.color = finalColor * input.color;
    }
}

// ============================================
// Color Picker - Saturation/Value Square Pass
// Renders a square where X = Saturation, Y = Value (brightness)
// for a given Hue value passed via resources.hue
// ============================================
pass "ColorSVPass" {
    use attributes { position, texcoord, color }

    vertex {
        mat4 orthoProjection = mat4(
            float4(2.0 / resources.screenSize.x, 0.0, 0.0, 0.0),
            float4(0.0, 2.0 / resources.screenSize.y, 0.0, 0.0),
            float4(0.0, 0.0, 1.0, 0.0),
            float4(-1.0, -1.0, 0.0, 1.0)
        );

        output.position = orthoProjection * float4(attributes.position, 1.0);
        output.texCoord = attributes.texcoord;
        output.color = attributes.color;
    }

    fragment {
        float2 uv = input.texCoord;
        float hue = resources.hue;  // 0-360 degrees
        
        // UV.x = Saturation (0-1), UV.y = Value/Brightness (0-1)
        float s = uv.x;
        float v = uv.y;
        
        // HSV to RGB conversion
        float h = hue / 60.0;  // Sector 0-5
        float i = floor(h);
        float f = h - i;
        float p = v * (1.0 - s);
        float q = v * (1.0 - s * f);
        float t = v * (1.0 - s * (1.0 - f));
        
        float3 rgb;
        float sector = mod(i, 6.0);
        if (sector < 1.0) {
            rgb = float3(v, t, p);
        } else if (sector < 2.0) {
            rgb = float3(q, v, p);
        } else if (sector < 3.0) {
            rgb = float3(p, v, t);
        } else if (sector < 4.0) {
            rgb = float3(p, q, v);
        } else if (sector < 5.0) {
            rgb = float3(t, p, v);
        } else {
            rgb = float3(v, p, q);
        }
        
        output.color = float4(rgb, 1.0) * input.color;
    }
}

// ============================================
// Color Picker - Hue Slider Pass
// Renders a horizontal rainbow gradient (full hue spectrum)
// ============================================
pass "ColorHuePass" {
    use attributes { position, texcoord, color }

    vertex {
        mat4 orthoProjection = mat4(
            float4(2.0 / resources.screenSize.x, 0.0, 0.0, 0.0),
            float4(0.0, 2.0 / resources.screenSize.y, 0.0, 0.0),
            float4(0.0, 0.0, 1.0, 0.0),
            float4(-1.0, -1.0, 0.0, 1.0)
        );

        output.position = orthoProjection * float4(attributes.position, 1.0);
        output.texCoord = attributes.texcoord;
        output.color = attributes.color;
    }

    fragment {
        float2 uv = input.texCoord;
        
        // Map UV.x to hue (0-360), full saturation and value
        float hue = uv.x * 360.0;
        float s = 1.0;
        float v = 1.0;
        
        // HSV to RGB conversion
        float h = hue / 60.0;
        float i = floor(h);
        float f = h - i;
        float p = v * (1.0 - s);
        float q = v * (1.0 - s * f);
        float t = v * (1.0 - s * (1.0 - f));
        
        float3 rgb;
        float sector = mod(i, 6.0);
        if (sector < 1.0) {
            rgb = float3(v, t, p);
        } else if (sector < 2.0) {
            rgb = float3(q, v, p);
        } else if (sector < 3.0) {
            rgb = float3(p, v, t);
        } else if (sector < 4.0) {
            rgb = float3(p, q, v);
        } else if (sector < 5.0) {
            rgb = float3(t, p, v);
        } else {
            rgb = float3(v, p, q);
        }
        
        output.color = float4(rgb, 1.0) * input.color;
    }
}

// ============================================
// Color Picker - Alpha Slider Pass
// Renders alpha gradient from transparent to solid color
// over a checkerboard background pattern
// ============================================
pass "ColorAlphaPass" {
    use attributes { position, texcoord, color }

    vertex {
        mat4 orthoProjection = mat4(
            float4(2.0 / resources.screenSize.x, 0.0, 0.0, 0.0),
            float4(0.0, 2.0 / resources.screenSize.y, 0.0, 0.0),
            float4(0.0, 0.0, 1.0, 0.0),
            float4(-1.0, -1.0, 0.0, 1.0)
        );

        output.position = orthoProjection * float4(attributes.position, 1.0);
        output.texCoord = attributes.texcoord;
        output.color = attributes.color;
    }

    fragment {
        float2 uv = input.texCoord;
        float3 baseColor = resources.baseColor.rgb;  // The RGB color (without alpha)
        float2 rectSize = resources.rectSize;
        
        // Create checkerboard pattern for alpha visualization
        float checkerSize = 8.0;  // Size of checker squares in pixels
        float2 pixelPos = uv * rectSize;
        float2 checker = floor(pixelPos / checkerSize);
        float checkerPattern = mod(checker.x + checker.y, 2.0);
        float3 checkerColor = lerp(float3(0.4, 0.4, 0.4), float3(0.6, 0.6, 0.6), checkerPattern);
        
        // Alpha gradient from left (transparent) to right (opaque)
        float alpha = uv.x;
        
        // Blend color over checkerboard based on alpha
        float3 finalColor = lerp(checkerColor, baseColor, alpha);
        
        output.color = float4(finalColor, 1.0) * input.color;
    }
}

// ============================================
// Color Picker - Checkerboard Pass
// Renders a checkerboard pattern for alpha preview backgrounds
// ============================================
pass "CheckerboardPass" {
    use attributes { position, texcoord, color }

    vertex {
        mat4 orthoProjection = mat4(
            float4(2.0 / resources.screenSize.x, 0.0, 0.0, 0.0),
            float4(0.0, 2.0 / resources.screenSize.y, 0.0, 0.0),
            float4(0.0, 0.0, 1.0, 0.0),
            float4(-1.0, -1.0, 0.0, 1.0)
        );

        output.position = orthoProjection * float4(attributes.position, 1.0);
        output.texCoord = attributes.texcoord;
        output.color = attributes.color;
    }

    fragment {
        float2 uv = input.texCoord;
        float2 rectSize = resources.rectSize;
        
        // Create checkerboard pattern
        float checkerSize = 8.0;  // Size of checker squares in pixels
        float2 pixelPos = uv * rectSize;
        float2 checker = floor(pixelPos / checkerSize);
        float checkerPattern = mod(checker.x + checker.y, 2.0);
        
        // Light and dark gray squares
        float3 checkerColor = lerp(float3(0.3, 0.3, 0.3), float3(0.5, 0.5, 0.5), checkerPattern);
        
        output.color = float4(checkerColor, 1.0) * input.color;
    }
}

// ============================================
// Color Picker - Preview Swatch Pass
// Renders a color preview with optional checkerboard for alpha
// ============================================
pass "ColorPreviewPass" {
    use attributes { position, texcoord, color }

    vertex {
        mat4 orthoProjection = mat4(
            float4(2.0 / resources.screenSize.x, 0.0, 0.0, 0.0),
            float4(0.0, 2.0 / resources.screenSize.y, 0.0, 0.0),
            float4(0.0, 0.0, 1.0, 0.0),
            float4(-1.0, -1.0, 0.0, 1.0)
        );

        output.position = orthoProjection * float4(attributes.position, 1.0);
        output.texCoord = attributes.texcoord;
        output.color = attributes.color;
    }

    fragment {
        float2 uv = input.texCoord;
        float4 previewColor = resources.previewColor;  // RGBA color to preview
        float2 rectSize = resources.rectSize;

        // Create checkerboard pattern for alpha visualization
        float checkerSize = 6.0;
        float2 pixelPos = uv * rectSize;
        float2 checker = floor(pixelPos / checkerSize);
        float checkerPattern = mod(checker.x + checker.y, 2.0);
        float3 checkerColor = lerp(float3(0.4, 0.4, 0.4), float3(0.6, 0.6, 0.6), checkerPattern);

        // Blend preview color over checkerboard
        float3 finalColor = lerp(checkerColor, previewColor.rgb, previewColor.a);

        output.color = float4(finalColor, 1.0) * input.color;
    }
}

// ============================================
// Focused Window Pass (gradient stroke + soft drop shadow)
// ============================================
pass "FocusedWindowPass" {
    use attributes { position, texcoord, color }

    vertex {
        mat4 orthoProjection = mat4(
            float4(2.0 / resources.screenSize.x, 0.0, 0.0, 0.0),
            float4(0.0, 2.0 / resources.screenSize.y, 0.0, 0.0),
            float4(0.0, 0.0, 1.0, 0.0),
            float4(-1.0, -1.0, 0.0, 1.0)
        );

        output.position = orthoProjection * float4(attributes.position, 1.0);
        output.texCoord = attributes.texcoord;
        output.color    = attributes.color;
    }

    fragment {
        float borderWidth      = resources.borderWidth;
        float2 windowSize      = resources.windowSize;
        float radius           = resources.cornerRadii.x;
        float2 shadowPadding   = resources.shadowPadding;
        float2 expandedSize    = float2(windowSize.x + borderWidth * 2.0, windowSize.y + shadowPadding.y + borderWidth);
        float2 posExpanded     = input.texCoord * expandedSize;
        float2 posWindow       = posExpanded - float2(borderWidth, shadowPadding.y);

        float2 halfSize        = windowSize * 0.5;
        float2 centered        = posWindow - halfSize;
        float2 q               = abs(centered) - halfSize + radius;
        float dist             = min(max(q.x, q.y), 0.0) + length(max(q, 0.0)) - radius;

        float smoothing        = fwidth(dist);

        float outerEdge        = smoothstep(-smoothing, smoothing, dist);
        float innerEdge        = smoothstep(-smoothing, smoothing, dist - borderWidth);
        float borderAlpha      = outerEdge - innerEdge;

        float angle            = resources.time * resources.rotationSpeed;
        float2 dir             = float2(cos(angle), sin(angle));
        float2 safeWindowSize  = float2(max(windowSize.x, 1.0), max(windowSize.y, 1.0));
        float2 gradPos         = (posWindow / safeWindowSize) - 0.5;
        float t                = clamp(dot(gradPos, dir) + 0.5, 0.0, 1.0);
        float4 borderColor     = lerp(resources.borderColor1, resources.borderColor2, t);

        float2 shadowPos       = posWindow + float2(0.0, resources.shadowOffsetY);
        float2 shadowCentered  = shadowPos - halfSize;
        float2 shadowQ         = abs(shadowCentered) - halfSize + radius;
        float distShadow       = min(max(shadowQ.x, shadowQ.y), 0.0) + length(max(shadowQ, 0.0)) - radius;

        float shadowMask       = select(0.0, 1.0, distShadow >= 0.0);
        float shadowAlpha      = (1.0 - smoothstep(0.0, resources.shadowBlur + smoothing, distShadow)) * shadowMask;
        shadowAlpha            *= resources.shadowColor.a;

        float borderAlphaFinal = borderAlpha * resources.opacity;
        float finalAlpha       = borderAlphaFinal + shadowAlpha * (1.0 - borderAlphaFinal);
        float3 premul          = borderColor.rgb * borderAlphaFinal + resources.shadowColor.rgb * shadowAlpha;
        float3 finalColor      = finalAlpha > 0.0 ? premul / finalAlpha : float3(0.0, 0.0, 0.0);

        if (finalAlpha < 0.01) {
            discard;
        }

        output.color = float4(finalColor, finalAlpha);
    }
}

}
