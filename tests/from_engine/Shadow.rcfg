# Shadow Pipeline - Shadow Map Generation
pipeline Shadow

# ============= TARGETS =============
target ShadowMap Depth32Float 2048 2048
target PointShadowMap Depth32Float 1024 1024

# ============= UNIFORMS =============
# Note: indices 0-9 reserved for vertex attribute buffers
uniform lightViewProjMatrix mat4 10 vertex

# ============= STORAGE BUFFERS =============
buffer drawMetadata DrawMetadata 15 readonly vertex
buffer transformBuffer mat4 16 readonly vertex

# Point/spot light parameters
uniform lightPosition float3 2 fragment
uniform farPlane float 3 fragment

# Alpha test
uniform alphaThreshold float 4 fragment
uniform albedoTexture sampler2D 5 fragment
uniform textureSampler sampler 6 fragment

# ============= PASSES =============
pass ShadowPass
  type geometry
  depth ShadowMap clear 1.0 store
  depends none

pass ShadowPassAlphaTest
  type geometry
  depth ShadowMap load store
  depends ShadowPass

pass PointShadowPass
  type geometry
  depth PointShadowMap clear 1.0 store
  depends none

pass SpotShadowPass
  type geometry
  depth ShadowMap clear 1.0 store
  depends none
