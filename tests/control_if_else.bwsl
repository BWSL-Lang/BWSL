// Test: If/else control flow
// Tests: if, else, else if, nested conditionals

pipeline ControlIfElse {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            float x = 0.5;

            // Simple if
            float result1 = 0.0;
            if (x > 0.0) {
                result1 = 1.0;
            }

            // If-else
            float result2 = 0.0;
            if (x > 0.5) {
                result2 = 1.0;
            } else {
                result2 = -1.0;
            }

            // If-else if-else chain
            float result3 = 0.0;
            if (x < 0.25) {
                result3 = 0.0;
            } else if (x < 0.5) {
                result3 = 0.25;
            } else if (x < 0.75) {
                result3 = 0.5;
            } else {
                result3 = 1.0;
            }

            // Nested if statements
            float result4 = 0.0;
            if (x > 0.0) {
                if (x < 1.0) {
                    result4 = x;
                } else {
                    result4 = 1.0;
                }
            } else {
                result4 = 0.0;
            }

            // Boolean condition in if
            bool condition = x > 0.3;
            float result5 = 0.0;
            if (condition) {
                result5 = 1.0;
            }

            // Complex condition
            float y = 0.7;
            float result6 = 0.0;
            if ((x > 0.0) && (y > 0.0)) {
                result6 = x * y;
            }

            // If with logical OR
            float result7 = 0.0;
            if ((x < 0.0) || (y > 0.5)) {
                result7 = 1.0;
            }

            // Negated condition
            bool isHidden = false;
            float result8 = 0.0;
            if (!isHidden) {
                result8 = 1.0;
            }

            // Multiple statements in block
            float result9 = 0.0;
            float temp = 0.0;
            if (x > 0.0) {
                temp = x * 2.0;
                result9 = temp + 1.0;
            }

            // Comparison chain via else-if
            int value = 2;
            float result10 = 0.0;
            if (value == 0) {
                result10 = 0.0;
            } else if (value == 1) {
                result10 = 0.25;
            } else if (value == 2) {
                result10 = 0.5;
            } else if (value == 3) {
                result10 = 0.75;
            } else {
                result10 = 1.0;
            }

            output.position = float4(attributes.position, 1.0);
        }

        fragment {
            float x = 0.5;
            float3 color = float3(0.0);

            // If in fragment shader
            if (x > 0.5) {
                color = float3(1.0, 0.0, 0.0);
            } else {
                color = float3(0.0, 0.0, 1.0);
            }

            output.color = float4(color, 1.0);
        }
    }
}
