# Character Pipeline - Basic PBR Rendering
pipeline Character

# ============= TARGETS =============
target SceneColor RGBA16Float viewport
target SceneDepth Depth32Float viewport

# ============= UNIFORMS =============
# Transform matrices (vertex stage)
uniform modelMatrix mat4 0 vertex

# View uniforms (both stages)
uniform viewMatrix mat4 1 both
uniform projectionMatrix mat4 2 both
uniform cameraPosition float4 3 both

# Lighting uniforms (fragment stage)
uniform lightDirection float4 4 fragment
uniform lightColor float4 5 fragment
uniform lightIntensity float 6 fragment

# PBR Textures (fragment stage)
uniform albedoTexture sampler2D 7 fragment
uniform normalMap sampler2D 8 fragment
uniform roughnessMap sampler2D 9 fragment
uniform metallicMap sampler2D 10 fragment
uniform aoMap sampler2D 11 fragment

# Sampler
uniform textureSampler sampler 12 fragment

# ============= PASSES =============
pass OpaquePass
  type geometry
  color SceneColor clear 0.1 0.1 0.1 1.0 store
  depth SceneDepth clear 1.0 store
  depends none
