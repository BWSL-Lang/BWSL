// ============================================
// Character Pipeline - Basic PBR Shading
// ============================================
pipeline Character {

import Math
import Compression, Color

// ============================================
// Vertex Attributes (with compression)
// ============================================
attributes {
    position: float3 @compressed(10_10_10)
    normal: float3 @compressed(octahedral16)
    texcoord: float2 @compressed(unorm16_16)
    tangent: float3 @compressed(octahedral16) 
    bitangent: float3 @compressed(octahedral16)
}

// ============================================
// PBR Helper Functions
// ============================================

// Fresnel-Schlick approximation
fresnelSchlick :: (float cosTheta, float3 F0) -> float3 {
    return F0 + (1.0 - F0) * pow(saturate(1.0 - cosTheta), 5.0);
}

// GGX/Trowbridge-Reitz normal distribution
distributionGGX :: (float3 N, float3 H, float roughness) -> float {
    float a = roughness * roughness;
    float a2 = a * a;
    float NdotH = max(dot(N, H), 0.0);
    float NdotH2 = NdotH * NdotH;

    float denom = (NdotH2 * (a2 - 1.0) + 1.0);
    denom = 3.14159265 * denom * denom;

    return a2 / denom;
}

// Schlick-GGX geometry function
geometrySchlickGGX :: (float NdotV, float roughness) -> float {
    float r = (roughness + 1.0);
    float k = (r * r) / 8.0;
    return NdotV / (NdotV * (1.0 - k) + k);
}

// Smith's geometry function
geometrySmith :: (float3 N, float3 V, float3 L, float roughness) -> float {
    float NdotV = max(dot(N, V), 0.0);
    float NdotL = max(dot(N, L), 0.0);
    float ggx1 = geometrySchlickGGX(NdotL, roughness);
    float ggx2 = geometrySchlickGGX(NdotV, roughness);
    return ggx1 * ggx2;
}

// ============================================
// Opaque Pass - PBR Rendering
// ============================================
pass "OpaquePass" {
    use attributes { position, normal, texcoord, tangent?, bitangent? }

    vertex {
        // Decompress vertex attributes
        float3 pos = Compression::decompressPosition_10_10_10(attributes.position);
        float3 norm = Compression::decompressOctahedral16(attributes.normal);
        float2 uv = Compression::decompressUV16_16(attributes.texcoord);

        float3 tang = float3(1.0, 0.0, 0.0);
        float3 bitang = float3(0.0, 0.0, 1.0);

        if (attributes.tangent) {
            tang = Compression::decompressOctahedral16(attributes.tangent);
        }
        if (attributes.bitangent) {
            bitang = Compression::decompressOctahedral16(attributes.bitangent);
        }

        // Transform to world space
        output.worldPos = (resources.modelMatrix * float4(pos, 1.0)).xyz;
        output.normal = normalize((resources.modelMatrix * float4(norm, 0.0)).xyz);
        output.tangent = normalize((resources.modelMatrix * float4(tang, 0.0)).xyz);
        output.bitangent = normalize((resources.modelMatrix * float4(bitang, 0.0)).xyz);
        output.texCoord = uv;

        // Calculate clip space position
        mat4 viewProjMatrix = resources.projectionMatrix * resources.viewMatrix;
        output.position = viewProjMatrix * float4(output.worldPos, 1.0);
    }

    fragment {
        // Sample PBR textures
        float4 albedoSample = sample(resources.albedoTexture, resources.textureSampler, input.texCoord);
        float3 albedo = Color::sRGBToLinear(albedoSample.rgb);

        float3 tangentNormal = sample(resources.normalMap, resources.textureSampler, input.texCoord).xyz * 2.0 - 1.0;
        float roughness = sample(resources.roughnessMap, resources.textureSampler, input.texCoord).r;
        float metallic = sample(resources.metallicMap, resources.textureSampler, input.texCoord).r;
        float ao = sample(resources.aoMap, resources.textureSampler, input.texCoord).r;

        // Construct TBN matrix and compute world-space normal
        mat3 TBN = mat3(input.tangent, input.bitangent, input.normal);
        float3 N = normalize(TBN * tangentNormal);

        // View direction
        float3 V = normalize(resources.cameraPosition.xyz - input.worldPos);

        // Base reflectivity (F0) - dielectric uses 0.04, metals use albedo
        float3 F0 = lerp(float3(0.04), albedo, metallic);

        // Simple directional light
        float3 lightDir = normalize(resources.lightDirection.xyz);
        float3 lightColor = resources.lightColor.rgb * resources.lightIntensity;

        float3 L = lightDir;
        float3 H = normalize(V + L);

        // Cook-Torrance BRDF
        float NDF = distributionGGX(N, H, roughness);
        float G = geometrySmith(N, V, L, roughness);
        float3 F = fresnelSchlick(max(dot(H, V), 0.0), F0);

        float3 kS = F;
        float3 kD = (1.0 - kS) * (1.0 - metallic);

        float NdotL = max(dot(N, L), 0.0);
        float NdotV = max(dot(N, V), 0.0);

        float3 numerator = NDF * G * F;
        float denominator = 4.0 * NdotV * NdotL + 0.0001;
        float3 specular = numerator / denominator;

        float3 Lo = (kD * albedo / 3.14159265 + specular) * lightColor * NdotL;

        // Ambient lighting (simple)
        float3 ambient = float3(0.03) * albedo * ao;

        // Final color
        float3 finalColor = ambient + Lo;

        // Tone mapping and gamma correction
        finalColor = Color::ACESFilm(finalColor);
        finalColor = Color::linearToSRGB(finalColor);

        output.color = float4(finalColor, albedoSample.a);
    }
}

}
