pipeline EquivNestedBreak {
    pass "Compute" {
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            uint cap = idx + 2u;
            float acc = 0.0;

            for (uint i = 0u; i < 8u; i = i + 1u) {
                if (i >= cap) {
                    break;
                }
                for (uint j = 0u; j < 8u; j = j + 1u) {
                    if (j > i) {
                        break;
                    }
                    if (j == 2u) {
                        continue;
                    }
                    acc = acc + float(i) * 0.1 + float(j) * 0.01;
                }
            }

            resources.output[idx] = acc;
        }
    }
}
