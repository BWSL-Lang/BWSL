pipeline EquivStructLocal {

struct Point {
    float3 pos;
    float weight;
};

    combine :: (Point a, Point b) -> float {
        float3 mixed = a.pos * a.weight + b.pos * b.weight;
        return mixed.x + mixed.y + mixed.z;
    }

    pass "Compute" {
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            float t = float(idx) * 0.5;

            Point p;
            p.pos = float3(t, t + 1.0, t + 2.0);
            p.weight = 0.25;

            Point q;
            q.pos = float3(t * 2.0, t + 0.5, t * 0.5);
            q.weight = 0.75;

            resources.output[idx] = combine(p, q);
        }
    }
}
