pipeline EquivIntegerOps {

    resources {
        output: buffer<int>
    }
    pass "Compute" {
        use resources { output }
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            int i = int(idx) + 1;

            int a = i * i - 3;
            int b = a % 7;
            int c = a << 2;
            int d = c >> 1;
            int e = (a & 0xF) | (b << 4);
            int result = a + b * 10 + d * 100 + e * 1000;

            resources.output[idx] = result;
        }
    }
}
