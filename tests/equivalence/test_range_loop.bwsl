pipeline EquivRangeLoop {

    resources {
        output: buffer<int>
    }
    pass "Compute" {
        use resources { output }
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            int limit = int(idx) + 3;

            int acc = 0;
            for (i in 0..limit) {
                acc = acc + i * (i - 1);
            }

            resources.output[idx] = acc;
        }
    }
}
