// Vector-boolean !, &&, ||, != must use logical SPIR-V ops
// (OpLogicalNot/And/Or/NotEqual) instead of bitwise/integer ops.
pipeline EquivBoolVecLogical {

    resources {
        output: buffer<float>
    }
    pass "Compute" {
        use resources { output }
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            float t = float(idx);

            float3 a = float3(t, t - 1.0, t - 2.0);
            float3 b = float3(1.0, 1.0, 1.0);

            bool3 lt = a < b;
            bool3 gt = a > b;

            bool3 notLt = !lt;                // vector NOT
            bool3 andv  = lt && gt;           // vector AND (all false)
            bool3 orv   = lt || gt;           // vector OR
            bool3 neq   = lt != gt;           // vector !=

            float acc = 0.0;
            if (notLt.x) acc = acc + 1.0;
            if (andv.x)  acc = acc + 2.0;
            if (orv.x)   acc = acc + 4.0;
            if (neq.x)   acc = acc + 8.0;
            if (notLt.y) acc = acc + 0.1;
            if (orv.z)   acc = acc + 0.01;

            resources.output[idx] = acc;
        }
    }
}
