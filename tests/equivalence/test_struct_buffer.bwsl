pipeline EquivStructBuffer {

struct Particle {
    float3 position;
    float mass;
    float3 velocity;
    float charge;
};

    pass "Compute" {
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            Particle p = resources.particles[idx];

            float energy = 0.5 * p.mass * dot(p.velocity, p.velocity);
            float potential = p.charge * (p.position.x + p.position.y + p.position.z);

            resources.output[idx] = energy + potential;
        }
    }
}
