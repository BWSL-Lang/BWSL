pipeline EquivBoolOps {

    resources {
        output: buffer<float>
    }
    pass "Compute" {
        use resources { output }
        compute "Main" [8, 1, 1] {
            uint idx = input.global_id.x;
            int i = int(idx);

            bool a = i > 2;
            bool b = i < 6;
            bool c = (i % 2) == 0;

            float r = 0.0;
            if (a && b) r = r + 10.0;
            if (a || c) r = r + 20.0;
            if (!a) r = r + 40.0;
            if (a && !b) r = r + 80.0;
            if ((a && b) || c) r = r + 160.0;
            if (!(a || c) && b) r = r + 320.0;

            resources.output[idx] = r;
        }
    }
}
