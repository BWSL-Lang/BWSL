pipeline EquivMat4Inverse {
    pass "Compute" {
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            float t = float(idx) * 0.2 + 0.1;

            mat4 M = mat4(
                float4(1.0 + t, t * 0.1, 0.0, 0.0),
                float4(t * 0.2, 2.0, 0.0, 0.0),
                float4(0.0, 0.0, 1.0, 0.0),
                float4(t, t * 2.0, t * 3.0, 1.0)
            );
            mat4 inv = inverse(M);
            mat4 product = M * inv;

            float4 p = float4(0.5, 1.0, 1.5, 1.0);
            float4 r = product * p;

            resources.output[idx] = r.x + r.y + r.z + r.w;
        }
    }
}
