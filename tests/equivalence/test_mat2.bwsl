pipeline EquivMat2 {
    pass "Compute" {
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            float t = float(idx) * 0.3;

            float c = cos(t);
            float s = sin(t);
            mat2 R = mat2(float2(c, s), float2(-s, c));
            mat2 S = mat2(float2(1.0 + t, 0.0), float2(0.0, 2.0 - t));
            mat2 M = R * S;

            float2 p = float2(1.0, 0.5);
            float2 r = M * p;
            mat2 T = transpose(M);
            float d = T[0].x + T[0].y + T[1].x + T[1].y;

            resources.output[idx] = r.x + r.y + d;
        }
    }
}
