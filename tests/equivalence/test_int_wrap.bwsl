pipeline EquivIntWrap {

    // Integer overflow / wrap semantics. SPIR-V's OpIAdd etc. wrap modulo
    // 2^32 by default. HLSL / GLSL match. Const folding in the compiler
    // must also wrap identically — this checks that.

    pass "Compute" {
        compute "Main" [8, 1, 1] {
            uint idx = input.global_id.x;
            int i = int(idx);

            // Wrap around INT32_MAX = 0x7FFFFFFF
            int big = 2147483647;
            int wrapped = big + i;              // idx=0 -> INT_MAX, idx>=1 -> wraps negative
            int wrappedSub = (-2147483647) - i - 1;  // pushes into INT_MIN territory
            int roundtrip = wrapped * 2;         // shifts off high bit

            // Unsigned wrap
            uint ubig = 4294967295u;             // 0xFFFFFFFF
            uint uwrap = ubig + idx;             // idx=0 -> max, idx=1 -> 0

            float score =
                float(wrapped)      * 0.00000001 +
                float(wrappedSub)   * 0.0000001  +
                float(roundtrip)    * 0.000001   +
                float(int(uwrap))   * 0.00001;

            resources.output[idx] = score;
        }
    }
}
