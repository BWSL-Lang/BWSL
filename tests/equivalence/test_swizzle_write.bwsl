pipeline EquivSwizzleWrite {
    pass "Compute" {
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            float t = float(idx);

            float4 v = float4(1.0, 2.0, 3.0, 4.0);
            v.x = t;
            v.yz = float2(t + 1.0, t + 2.0);
            v.wzyx = float4(10.0, 20.0, 30.0, 40.0);

            float3 u = float3(0.0);
            u.xz = v.xy;
            u.y = v.z;

            resources.output[idx] = v.x + v.y * 2.0 + v.z * 4.0 + v.w * 8.0
                                  + u.x * 16.0 + u.y * 32.0 + u.z * 64.0;
        }
    }
}
