pipeline EquivShadowingDeep {

    resources {
        output: buffer<float>
    }
    pass "Compute" {
        use resources { output }
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            float x = float(idx);
            float acc = 0.0;

            for (int i = 0; i < 4; i = i + 1) {
                for (int i = 0; i < 2; i = i + 1) {
                    acc = acc + float(i);
                }
            }

            {
                float x = 100.0;
                {
                    float x = 200.0;
                    acc = acc + x;
                }
                acc = acc + x;
            }

            acc = acc + x;
            resources.output[idx] = acc;
        }
    }
}
