pipeline EquivConditional {

    resources {
        output: buffer<float>
    }
    pass "Compute" {
        use resources { output }
        compute "Main" [8, 1, 1] {
            uint idx = input.global_id.x;
            int i = int(idx);
            float result = 0.0;

            if (i < 2) {
                result = 10.0 + float(i);
            } else if (i < 4) {
                result = 20.0 + float(i) * 2.0;
            } else if (i == 5) {
                result = 99.0;
            } else {
                result = (i % 2 == 0) ? 30.0 : 40.0;
                result = result + float(i) * 0.5;
            }

            bool positive = result > 0.0;
            bool even = (i % 2) == 0;
            result = positive && even ? result : -result;

            resources.output[idx] = result;
        }
    }
}
