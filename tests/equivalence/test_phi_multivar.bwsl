pipeline EquivPhiMultivar {

    resources {
        output: buffer<float>
    }
    pass "Compute" {
        use resources { output }
        compute "Main" [8, 1, 1] {
            uint idx = input.global_id.x;
            int i = int(idx);

            float a = 0.0;
            float b = 1.0;
            int count = 0;
            float product = 1.0;

            for (int k = 0; k < i + 3; k = k + 1) {
                if (k % 3 == 0) {
                    a = a + float(k);
                    count = count + 1;
                } else if (k % 3 == 1) {
                    b = b * 2.0;
                    product = product * (float(k) + 0.5);
                } else {
                    a = a - 0.5;
                    b = b + float(k);
                    count = count + 2;
                }
            }

            resources.output[idx] = a * 100.0 + b + float(count) * 0.1 + product * 0.001;
        }
    }
}
