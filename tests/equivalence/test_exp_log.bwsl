pipeline EquivExpLog {

    resources {
        output: buffer<float>
    }
    pass "Compute" {
        use resources { output }
        compute "Main" [8, 1, 1] {
            uint idx = input.global_id.x;
            float t = float(idx) * 0.5 + 0.5;

            float e = exp(t * 0.2);
            float e2 = exp2(t);
            float l = log(t);
            float l2 = log2(t * 4.0);
            float s = sqrt(t);
            float rs = rsqrt(t + 1.0);
            float p = pow(t, 1.5);
            float p2 = pow(2.0, t);

            resources.output[idx] = e + e2 * 0.1 + l + l2 * 0.5
                                  + s * 2.0 + rs * 3.0
                                  + p * 0.25 + p2 * 0.1;
        }
    }
}
