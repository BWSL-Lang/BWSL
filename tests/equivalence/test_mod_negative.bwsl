pipeline EquivModNegative {

    resources {
        output: buffer<float>
    }
    pass "Compute" {
        use resources { output }
        compute "Main" [8, 1, 1] {
            uint idx = input.global_id.x;
            int i = int(idx) - 4;

            int a = i % 3;
            float f = float(i) * 0.5;
            float fm = mod(f, 3.0);
            float fm2 = mod(-f, 2.5);

            resources.output[idx] = float(a) + fm * 10.0 + fm2 * 100.0;
        }
    }
}
