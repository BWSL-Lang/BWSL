pipeline EquivMath {

    resources {
        output: buffer<float>
    }
    pass "Compute" {
        use resources { output }
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            float t = float(idx) * 0.1;
            float3 v = float3(t, t * 2.0, t * 3.0);
            float n = length(v);
            float m = dot(v, float3(1.0, 0.5, 0.25));
            float s = smoothstep(0.0, 1.0, t);
            float c = clamp(m, 0.0, 1.0);
            resources.output[idx] = n + m + s + c;
        }
    }
}
