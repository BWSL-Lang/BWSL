pipeline EquivInlineReturnNestedLoops {

    chooseNested :: (int limit) -> int {
        for (int i = 0; i < limit; i = i + 1) {
            for (int j = 0; j < limit; j = j + 1) {
                return 5;
            }
        }
        return 8;
    }

    pass "Compute" {
        compute "Main" [8, 1, 1] {
            uint idx = input.global_id.x;
            int limit = int(idx);  // 0 -> outer skipped; >=1 -> inner returns
            int v = chooseNested(limit);
            resources.output[idx] = float(v);
        }
    }
}
