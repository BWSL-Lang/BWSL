pipeline EquivMatrixMixedCtor {

    resources {
        output: buffer<float>
    }

    // Matrix construction from varied operand mixes — a common point of
    // cross-backend divergence (column-major vs row-major interpretation,
    // vector vs scalar unpacking order).

    pass "Compute" {
        use resources { output }
        compute "Main" [8, 1, 1] {
            uint idx = input.global_id.x;
            float t = float(idx);

            // mat3 from 3 float3 columns
            float3 c0 = float3(t,        t + 1.0,  t + 2.0);
            float3 c1 = float3(t + 10.0, t + 11.0, t + 12.0);
            float3 c2 = float3(t + 20.0, t + 21.0, t + 22.0);
            float3x3 m3 = float3x3(c0, c1, c2);

            // mat4 from 16 scalars
            float4x4 m4 = float4x4(
                t,        t + 1.0,  t + 2.0,  t + 3.0,
                t + 4.0,  t + 5.0,  t + 6.0,  t + 7.0,
                t + 8.0,  t + 9.0,  t + 10.0, t + 11.0,
                t + 12.0, t + 13.0, t + 14.0, t + 15.0);

            // Sample a representative fold so the runner sees a single float
            // per thread.
            float score =
                m3[0][0] + m3[1][1] + m3[2][2] +   // diagonal
                m3[0][2] * 0.1 +                    // off-diag
                m4[0][3] * 0.01 +                   // corner
                m4[2][1] * 0.001 +
                m4[3][3] * 0.0001;

            resources.output[idx] = score;
        }
    }
}
