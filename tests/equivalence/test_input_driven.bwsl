pipeline EquivInputDriven {

    resources {
        inbuf: buffer<float>
        output: buffer<float>
    }
    pass "Compute" {
        use resources { inbuf, output }
        compute "Main" [8, 1, 1] {
            uint idx = input.global_id.x;
            float v = resources.inbuf[idx];
            float prev = resources.inbuf[(idx + 7u) % 8u];
            float transformed = v * v - prev * 0.5 + 1.0;
            resources.output[idx] = transformed;
        }
    }
}
