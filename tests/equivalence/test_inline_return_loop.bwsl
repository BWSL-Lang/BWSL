pipeline EquivInlineReturnLoop {

    chooseLoop :: (int limit) -> int {
        for (int i = 0; i < limit; i = i + 1) {
            return 7;
        }
        return 9;
    }

    pass "Compute" {
        compute "Main" [8, 1, 1] {
            uint idx = input.global_id.x;
            int limit = int(idx) - 2;  // mix of zero-iteration and one+
            int v = chooseLoop(limit);
            resources.output[idx] = float(v);
        }
    }
}
