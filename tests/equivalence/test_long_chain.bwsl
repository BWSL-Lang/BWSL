pipeline EquivLongChain {

    resources {
        output: buffer<float>
    }
    pass "Compute" {
        use resources { output }
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            float t = float(idx) * 0.1 + 0.5;

            float a = t;
            float b = a * 1.1 + 0.2;
            float c = b * 1.2 - 0.3;
            float d = c * 1.3 + 0.4;
            float e = d * 1.4 - 0.5;
            float f = e + a;
            float g = f * b - c;
            float h = g + d * e;
            float i = h / (f + 0.1);
            float j = i * g + h * 0.25;
            float k = j - i * 0.5 + a * b;
            float l = k * c + d * e;
            float m = l + (a + b) * (c + d);
            float n = m - sqrt(abs(l) + 0.01);
            float o = n + exp(a * 0.1) * cos(b);
            float p = o - sin(c) * tan(d * 0.1);
            float q = p + a * b * c * d * e;
            float r = q - (f + g + h + i + j) * 0.1;
            float s = r * 0.5 + (k + l + m + n + o) * 0.25;
            float u = s + p - q * 0.1 + r * 0.05;

            resources.output[idx] = u;
        }
    }
}
