pipeline EquivCompoundAssign {
    pass "Compute" {
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            float s = float(idx) + 1.0;

            float a = 2.0;
            a += s;
            a *= 1.5;
            a -= 0.5;
            a /= 2.0;

            float3 v = float3(1.0, 2.0, 3.0);
            v += float3(s, s * 0.5, s * 0.25);
            v *= 2.0;
            v -= float3(1.0, 1.0, 1.0);

            resources.output[idx] = a + v.x + v.y * 2.0 + v.z * 3.0;
        }
    }
}
