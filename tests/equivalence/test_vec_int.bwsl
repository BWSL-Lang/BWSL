pipeline EquivVecInt {
    pass "Compute" {
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            int i = int(idx) + 1;

            int3 a = int3(i, i * 2, i * 3);
            int3 b = int3(i + 1, i - 1, i * 2);
            int3 sum = a + b;
            int3 diff = a - b;
            int3 prod = a * b;

            int folded = sum.x * 1 + sum.y * 10 + sum.z * 100
                       + diff.x * 1000 + prod.x * 10000;

            resources.output[idx] = folded;
        }
    }
}
