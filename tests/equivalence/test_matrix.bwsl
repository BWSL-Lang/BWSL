pipeline EquivMatrix {
    pass "Compute" {
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            float t = float(idx) * 0.25;
            float scale = t + 1.0;

            mat4 S = mat4(
                float4(scale, 0.0, 0.0, 0.0),
                float4(0.0, scale, 0.0, 0.0),
                float4(0.0, 0.0, scale, 0.0),
                float4(0.0, 0.0, 0.0, 1.0)
            );
            float c = cos(t);
            float s = sin(t);
            mat4 R = mat4(
                float4(c, s, 0.0, 0.0),
                float4(-s, c, 0.0, 0.0),
                float4(0.0, 0.0, 1.0, 0.0),
                float4(0.0, 0.0, 0.0, 1.0)
            );
            mat4 M = R * S;
            float4 p = float4(1.0, 2.0, 3.0, 1.0);
            float4 r = M * p;
            resources.output[idx] = r.x + r.y + r.z + r.w;
        }
    }
}
