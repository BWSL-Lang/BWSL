pipeline EquivMatrixIndexing {
    pass "Compute" {
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            int i = int(idx);

            mat4 M = mat4(
                float4(1.0, 2.0, 3.0, 4.0),
                float4(5.0, 6.0, 7.0, 8.0),
                float4(9.0, 10.0, 11.0, 12.0),
                float4(13.0, 14.0, 15.0, 16.0)
            );

            float4 col = M[i];
            float elem = M[i][(i + 1) % 4];
            float diag = M[0][0] + M[1][1] + M[2][2] + M[3][3];

            resources.output[idx] = col.x + col.y + col.z + col.w + elem * 100.0 + diag;
        }
    }
}
