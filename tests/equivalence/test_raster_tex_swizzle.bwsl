// Equivalence: sample a 2D texture and emit the channels in BGRA order.
// Exercises swizzle on the sampled result after a combined image sampler
// fetch, confirming that channel re-ordering survives SPIRV-Cross round
// trips through both HLSL and GLSL.
pipeline EquivRasterTexSwizzle {
    attributes {
    }

    pass "Main" {
        vertex {
            float2[3] positions;
            positions[0] = float2(-1.0, -1.0);
            positions[1] = float2( 3.0, -1.0);
            positions[2] = float2(-1.0,  3.0);

            float2 p = positions[input.vertex_id];
            output.position = float4(p, 0.0, 1.0);
            output.uv = (p + 1.0) * 0.5;
        }

        fragment {
            float4 t = sample(resources.colorTex, resources.colorSampler,
                              input.uv);
            output.color = float4(t.b, t.g, t.r, t.a);
        }
    }
}
