pipeline EquivPhiLoop {

    resources {
        output: buffer<float>
    }
    pass "Compute" {
        use resources { output }
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            uint n = idx + 4u;
            float acc = 0.0;
            for (uint i = 0u; i < n; i = i + 1u) {
                float fi = float(i);
                if (i % 2u == 0u) {
                    acc = acc + fi;
                } else {
                    acc = acc - fi * 0.5;
                }
            }
            resources.output[idx] = acc;
        }
    }
}
