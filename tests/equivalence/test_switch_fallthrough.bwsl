pipeline EquivSwitchFallthrough {

    resources {
        output: buffer<float>
    }

    // Exercises switch fall-through semantics: cases without `break` fall
    // through to the next case. Backend divergence risk is high here —
    // GLSL/HLSL/SPIRV have subtly different handling of missing-break.
    classify :: (int v) -> float {
        float r = 0.0;
        switch (v) {
            case 0:
                r = 1.0;
                break;
            case 1:
            case 2:
                // Shared case entry — both 1 and 2 land here
                r = 10.0;
                break;
            case 3:
                r = 100.0;
                // fall through to case 4
            case 4:
                r = r + 1000.0;
                break;
            default:
                r = -1.0;
        }
        return r;
    }

    pass "Compute" {
        use resources { output }
        compute "Main" [8, 1, 1] {
            uint idx = input.global_id.x;
            int v = int(idx) - 1;  // -1, 0, 1, 2, 3, 4, 5, 6 -> hits default/0/1/2/3/4/default/default
            resources.output[idx] = classify(v);
        }
    }
}
