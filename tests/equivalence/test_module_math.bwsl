pipeline EquivModuleMath {

    resources {
        output: buffer<float>
    }
    import Math

    pass "Compute" {
        use resources { output }
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            float t = float(idx) * 0.25 + 0.1;

            float r1 = Math::inverse_lerp(0.0, 2.0, t);
            float r2 = Math::remap(t, 0.0, 1.0, 5.0, 10.0);
            float r3 = Math::safe_divide(t, t - 0.5);

            float3 v = float3(t, t * 2.0, t * 3.0);
            float3 sn = Math::safe_normalize(v);

            resources.output[idx] = r1 + r2 + r3 + sn.x + sn.y + sn.z + Math::PI * 0.01;
        }
    }
}
