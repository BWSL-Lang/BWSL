pipeline EquivMatParam {

    apply_transform :: (mat4 M, float4 p) -> float4 {
        return M * p;
    }

    sum_matrix :: (mat4 M) -> float {
        return M[0].x + M[1].y + M[2].z + M[3].w;
    }

    scaled :: (mat3 M, float factor) -> mat3 {
        return M * factor;
    }

    pass "Compute" {
        compute "Main" [4, 1, 1] {
            uint idx = input.global_id.x;
            float t = float(idx) * 0.25;

            mat4 M = mat4(
                float4(1.0 + t, 0.0, 0.0, 0.0),
                float4(0.0, 2.0, 0.0, 0.0),
                float4(0.0, 0.0, 3.0, 0.0),
                float4(t, t * 2.0, t * 3.0, 1.0)
            );
            float4 p = float4(0.5, 0.25, 0.125, 1.0);
            float4 r = apply_transform(M, p);
            float s = sum_matrix(M);

            mat3 N = mat3(float3(1.0, 2.0, 3.0), float3(4.0, 5.0, 6.0), float3(7.0, 8.0, 9.0));
            mat3 N2 = scaled(N, t + 1.0);
            float ns = N2[0].x + N2[1].y + N2[2].z;

            resources.output[idx] = r.x + r.y + r.z + r.w + s * 0.25 + ns * 0.1;
        }
    }
}
