// Equivalence: vec3 normalize / dot / cross / length in fragment. Confirms
// that vector intrinsics produce identical pixels across backends.
pipeline EquivRasterVecOps {
    attributes { }

    pass "Main" {
        vertex {
            float2[3] positions;
            positions[0] = float2(-1.0, -1.0);
            positions[1] = float2( 3.0, -1.0);
            positions[2] = float2(-1.0,  3.0);
            float2 p = positions[input.vertex_id];
            output.position = float4(p, 0.0, 1.0);
            output.uv = (p + 1.0) * 0.5;
        }

        fragment {
            float2 uv = input.uv;
            float3 a = normalize(float3(uv.x + 0.2, uv.y + 0.2, 1.0));
            float3 b = normalize(float3(uv.y + 0.1, -uv.x + 0.3, 0.5));
            float d = dot(a, b);
            float3 x = cross(a, b);
            float ln = length(x);
            float3 color = float3(d * 0.5 + 0.5, ln, x.z * 0.5 + 0.5);
            output.color = float4(color, 1.0);
        }
    }
}
