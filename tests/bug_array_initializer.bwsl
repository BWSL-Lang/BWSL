// BUG: Array initializer syntax { ... } not supported
// Expected: Should allow inline array initialization
// Actual: Parse error

pipeline BugArrayInitializer {

    resources {
        viewMatrix: mat4
        projectionMatrix: mat4
        modelMatrix: mat4
        viewProjMatrix: mat4
        lightViewProjMatrix: mat4
        particles: buffer<Particle>
    }

attributes {
    position: float3
}

pass "Test" {
        use resources { viewMatrix, projectionMatrix, modelMatrix, viewProjMatrix, lightViewProjMatrix, particles }
    use attributes { position }

    vertex {
        // This syntax fails - need element-by-element instead
        float2[3] positions = {
            float2(-1.0, -1.0),
            float2( 3.0, -1.0),
            float2(-1.0,  3.0)
        };

        output.position = float4(positions[input.vertex_id], 0.0, 1.0);
    }

    fragment {
        output.color = float4(1.0);
    }
}

}
