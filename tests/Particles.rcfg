# Particles Pipeline - GPU Particle Effects
pipeline Particles

# ============= TARGETS =============
target ParticleColor RGBA16Float viewport
target SceneDepth Depth32Float viewport

# ============= UNIFORMS =============
# Transform matrices (vertex)
uniform viewMatrix mat4 0 vertex
uniform projectionMatrix mat4 1 vertex

# Particle buffer arrays (vertex)
uniform particlePositions buffer 2 vertex
uniform particleSizes buffer 3 vertex
uniform particleRotations buffer 4 vertex
uniform particleColors buffer 5 vertex
uniform particleLives buffer 6 vertex
uniform particleTexIndices buffer 7 vertex

# Screen parameters (fragment)
uniform screenSize float2 0 fragment
uniform softParticleFactor float 1 fragment

# Textures and samplers (fragment)
uniform particleTexture sampler2D 2 fragment
uniform textureSampler sampler 3 fragment
uniform depthBuffer sampler2D 4 fragment
uniform depthSampler sampler 5 fragment

# ============= PASSES =============
pass ParticlePass
  type geometry
  color ParticleColor load store
  depth SceneDepth load store
  depends none

pass ParticlePassAdditive
  type geometry
  color ParticleColor load store
  depth SceneDepth load store
  depends ParticlePass
