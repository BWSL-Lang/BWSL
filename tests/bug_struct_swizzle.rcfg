# Test config for larger struct swizzle test
pipeline LargeStructSwizzleTest

target Color RGBA8Unorm viewport
target Depth Depth32Float viewport

# Uniform struct matching shader definition  
uniform material GPUMaterialData 0 fragment

pass pass0
  type geometry
  color Color clear 0.0 0.0 0.0 1.0 store
  depth Depth clear 1.0 store
  depends none
