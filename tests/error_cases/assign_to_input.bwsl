// Error case: the input namespace is read-only in every stage.
pipeline AssignToInput {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            output.position = float4(attributes.position, 1.0);
            output.uv = attributes.position.xy;
        }

        fragment {
            input.uv = float2(0.0, 0.0);
            output.color = float4(input.uv, 0.0, 1.0);
        }
    }
}
