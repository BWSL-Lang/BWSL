pipeline StructMethodNonConstOnConstError {
    struct Thing {
        float v;

        touch :: () -> void {
            v = v + 1.0;
        }
    }

    pass "Compute" {
        compute "Main" [1, 1, 1] {
            Thing t;
            t.v = 1.0;
            const Thing frozen = t;
            frozen.touch();
        }
    }
}
