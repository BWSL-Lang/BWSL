// Error case: a call whose argument types match no overload exactly is
// rejected (two int literals, but only (float,int) and (int,float) exist).
pipeline OverloadNoViableMatch {
    attributes {
        position: float3
    }

    pickone :: (float x, int y) -> float {
        return x;
    }

    pickone :: (int x, float y) -> float {
        return y;
    }

    pass "Main" {
        use attributes { position }

        vertex {
            float r = pickone(1, 2);
            output.position = float4(attributes.position, r);
        }
    }
}
