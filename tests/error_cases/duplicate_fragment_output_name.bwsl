// Error case: fragment output names must be unique within an outputs block.
pipeline DuplicateFragmentOutputName {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        outputs {
            color: float4
            color: float4
        }

        vertex {
            output.position = float4(attributes.position, 1.0);
        }

        fragment {
            output.color = float4(1.0, 0.0, 0.0, 1.0);
        }
    }
}
