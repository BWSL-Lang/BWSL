// Error case: enum payload constructors take exactly the declared arguments.
pipeline WrongAcceptEnumPayloadArity {
    attributes {
        position: float3
    }

    enum Shape {
        Sphere(float radius),

        eval size :: () -> float {
            Sphere(r): r
        }
    }

    pass "Main" {
        use attributes { position }

        vertex {
            Shape s = Shape::Sphere(1.0, 2.0);
            output.position = float4(attributes.position, s.size());
        }
    }
}
