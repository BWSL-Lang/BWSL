// Error case: pass names must be unique within a pipeline.
pipeline WrongAcceptDuplicatePassName {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }
        vertex {
            output.position = float4(attributes.position, 1.0);
        }
    }

    pass "Main" {
        use attributes { position }
        vertex {
            output.position = float4(attributes.position, 2.0);
        }
    }
}
