// Error case: intrinsic called with fewer arguments than its minimum arity.
pipeline IntrinsicTooFewArgs {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            float bad = clamp(0.5, 0.0);
            output.position = float4(attributes.position * bad, 1.0);
        }
    }
}
