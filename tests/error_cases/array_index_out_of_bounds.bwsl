// Error case: statically out-of-bounds constant array indices.
pipeline WrongAcceptArrayOobConst {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            float[4] a;
            a[0] = 1.0;
            float past = a[7];
            float neg = a[-1];
            output.position = float4(attributes.position, past + neg);
        }
    }
}
