// Error case: passing a struct through a vertex-to-fragment varying.
// Currently rejected only when the emitted SPIR-V fails validation; a
// front-end diagnostic ("varyings must be scalar/vector") would be better.
pipeline StructAsVarying {
    attributes {
        position: float3
    }

    struct Packed {
        float a;
        float b;
    }

    pass "Main" {
        use attributes { position }

        vertex {
            Packed p;
            p.a = 1.0;
            p.b = 2.0;
            output.position = float4(attributes.position, 1.0);
            output.packed = p;
        }

        fragment {
            output.color = float4(input.packed.a, input.packed.b, 0.0, 1.0);
        }
    }
}
