// Error case: vertex attributes are read-only.
pipeline AssignToAttribute {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            attributes.position = float3(0.0, 0.0, 0.0);
            output.position = float4(attributes.position, 1.0);
        }
    }
}
