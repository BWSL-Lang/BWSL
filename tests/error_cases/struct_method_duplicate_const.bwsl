pipeline StructMethodDuplicateConstError {
    struct Thing {
        float v;

        value :: () const -> float {
            return v;
        }

        value :: () const -> float {
            return self.v;
        }
    }

    pass "Compute" {
        compute "Main" [1, 1, 1] {
            Thing t;
            t.v = 1.0;
        }
    }
}
