// Error case: shared arrays cannot have initializers.
pipeline SharedArrayInitializer {
    resources {
        data: buffer<float>
    }

    pass "Kernel" {
        use resources { data }

        compute "Main" [64, 1, 1] {
            shared float[64] scratch = { 0.0 };
            uint3 gid = input.global_id;
            resources.data[gid.x] = scratch[gid.x % 64u];
        }
    }
}
