pipeline InterpolationDecoratorConflict {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            output.position = float4(attributes.position, 1.0);
            @flat output.value = 1.0;
            @noperspective output.value = 2.0;
        }

        fragment {
            float value = input.value;
            output.color = float4(value, value, value, 1.0);
        }
    }
}
