pipeline InterpolationDecoratorNonOutput {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            float value = 0.0;
            @flat value = 1.0;
            output.position = float4(attributes.position, 1.0);
        }

        fragment {
            output.color = float4(1.0);
        }
    }
}
