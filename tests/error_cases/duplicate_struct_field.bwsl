// Error case: struct field names must be unique.
pipeline WrongAcceptDuplicateStructField {
    attributes {
        position: float3
    }

    struct Data {
        float a;
        float a;
    }

    pass "Main" {
        use attributes { position }

        vertex {
            Data d;
            d.a = 1.0;
            output.position = float4(attributes.position, d.a);
        }
    }
}
