// Error case: vector constructors must cover the component count exactly.
pipeline WrongAcceptVecCtorArity {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            float4 v = float4(1.0, 2.0, 3.0);
            output.position = v;
        }
    }
}
