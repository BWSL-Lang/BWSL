// Error case: enum member names must be unique.
pipeline WrongAcceptDuplicateEnumMember {
    attributes {
        position: float3
    }

    enum Mode { A, B, A }

    pass "Main" {
        use attributes { position }

        vertex {
            int m = Mode::A;
            output.position = float4(attributes.position, float(m));
        }
    }
}
