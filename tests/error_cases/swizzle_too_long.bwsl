// Error case: swizzles are limited to 4 components.
pipeline WrongAcceptSwizzleTooLong {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            float4 v = float4(attributes.position, 1.0);
            output.position = float4(v.xyzxy.x, 0.0, 0.0, 1.0);
        }
    }
}
