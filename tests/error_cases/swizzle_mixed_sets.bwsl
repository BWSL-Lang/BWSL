// Error case: swizzles cannot mix xyzw and rgba names.
pipeline WrongAcceptSwizzleMixedSets {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            float4 v = float4(attributes.position, 1.0);
            float2 m = v.xg;
            output.position = float4(m, 0.0, 1.0);
        }
    }
}
