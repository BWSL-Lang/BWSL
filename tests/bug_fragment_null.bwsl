// BUG: fragment = null syntax not supported for depth-only passes
// Expected: Allow depth-only rendering without fragment shader
// Actual: Syntax error

pipeline BugFragmentNull {

    resources {
        viewMatrix: mat4
        projectionMatrix: mat4
        modelMatrix: mat4
        viewProjMatrix: mat4
        lightViewProjMatrix: mat4
        particles: buffer<Particle>
    }

attributes {
    position: float3
}

pass "ShadowPass" {
        use resources { viewMatrix, projectionMatrix, modelMatrix, viewProjMatrix, lightViewProjMatrix, particles }
    use attributes { position }

    vertex {
        output.position = resources.lightViewProjMatrix * float4(attributes.position, 1.0);
    }

    // Depth-only pass - no fragment output needed
    fragment = null
}

}
