// Wrong-accept: assignments to the read-only `input` namespace compile and
// validate, but the store is silently dropped from the emitted SPIR-V. Both
// user varyings (input.uv) and built-ins (input.vertex_id) are affected.
// These should be rejected with "input is read-only" diagnostics.
pipeline WrongAcceptAssignToInput {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            input.vertex_id = 5u;
            output.position = float4(attributes.position, 1.0);
            output.uv = attributes.position.xy;
        }

        fragment {
            input.uv = float2(0.0, 0.0);
            output.color = float4(input.uv, 0.0, 1.0);
        }
    }
}
