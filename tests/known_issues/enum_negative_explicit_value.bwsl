// Known issue: explicit negative enum values are rejected at parse time
// with "Expected constant value after '='" — the enum value parser does not
// accept a unary minus. For an `: int`-typed enum, negative values should
// be representable.
pipeline EnumNegativeExplicitValue {
    attributes {
        position: float3
    }

    enum Bias : int {
        Negative = -1,
        Zero = 0,
        Positive = 1
    }

    pass "Main" {
        use attributes { position }

        vertex {
            int b = Bias::Negative;
            output.position = float4(attributes.position, float(b));
        }
    }
}
