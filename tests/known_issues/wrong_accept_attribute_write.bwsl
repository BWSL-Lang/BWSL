// Wrong-accept: assigning to a vertex attribute (stage input) compiles
// without diagnostics. Attributes should be read-only.
pipeline WrongAcceptAttributeWrite {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            attributes.position = float3(0.0, 0.0, 0.0);
            output.position = float4(attributes.position, 1.0);
        }
    }
}
