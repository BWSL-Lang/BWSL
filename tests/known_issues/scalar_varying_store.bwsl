// Known issue: scalar float varyings emit a type-mismatched OpStore.
// The varying interface variable is declared with a different type than the
// scalar being stored, so spirv-val rejects the vertex stage:
//   OpStore Pointer '[%varying0]'s type does not match Object '[%float_0_75]'s type
// Vector varyings (float2/float3/float4) work fine.
pipeline ScalarVaryingStore {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            output.position = float4(attributes.position, 1.0);
            output.brightness = 0.75;
        }

        fragment {
            output.color = float4(input.brightness, 0.0, 0.0, 1.0);
        }
    }
}
