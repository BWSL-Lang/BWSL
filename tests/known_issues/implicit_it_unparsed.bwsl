// Known issue: the implicit `it` iterator from `for (collection) { ... }`
// (docs/spec/05) cannot be referenced; the parser has no rule for
// TokenType::IT, so this fails with "Expected expression".
pipeline ImplicitItUnparsed {
    attributes { position: float3 }
    pass "Main" {
        use attributes { position }
        vertex {
            float weights[3] = { 0.1, 0.2, 0.3 };
            float s = 0.0;
            for (weights) {
                s = s + it;
            }
            output.position = float4(attributes.position * s, 1.0);
        }
    }
}
