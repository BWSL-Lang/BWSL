// Known issue: a resource declared directly with an array type
// (`weights: float4[8]`) compiles, but indexing it produces invalid SPIR-V:
//   error: Reached non-composite type while indexes still remain to be
//   traversed.  %32 = OpCompositeExtract %float %26 0
// `resources.weights[0]` appears to be typed as the whole array rather than
// the element. Wrapping the array in a struct (see
// tests/unsorted/resources_type_in_module_array.bwsl) works correctly.
pipeline ResourcesArrayTypeInvalidSpirv {
    attributes {
        position: float3
    }

    resources {
        weights: float4[8]
    }

    pass "Main" {
        use attributes { position }
        use resources { weights }

        vertex {
            float4 w0 = resources.weights[0];
            output.position = float4(attributes.position, w0.x);
        }
    }
}
