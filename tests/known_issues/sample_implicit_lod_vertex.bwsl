// Known issue: `sample()` in a vertex stage emits OpImageSampleImplicitLod,
// which SPIR-V only allows in fragment/compute-like execution models:
//   ImplicitLod instructions require Fragment, GLCompute, ... execution model
// Either a front-end diagnostic ("use sample_lod in vertex shaders") or an
// automatic lowering to explicit LOD 0 is needed. `sample_lod(...)` in vertex
// works today (covered by tests/unsorted/vertex_texture_fetch_lod.bwsl).
pipeline SampleImplicitLodVertex {
    attributes {
        position: float3
        texcoord: float2
    }

    resources {
        heightMap: texture2D
        heightSampler: sampler
    }

    pass "Main" {
        use attributes { position, texcoord }
        use resources { heightMap, heightSampler }

        vertex {
            float4 h = sample(resources.heightMap, resources.heightSampler, attributes.texcoord);
            output.position = float4(attributes.position + float3(0.0, h.r, 0.0), 1.0);
        }
    }
}
