// Known issue: descending range loops with a negative `by` step compile
// without diagnostics, but lowering keeps the ascending comparison, so the
// body never executes:
//   for (i in 8..0 by -2)  ->  for (i = 8; i < 0; i += -2)   // 0 iterations
//   for (j in 4..=1 by -1) ->  for (j = 4; j <= 1; j += -1)  // 0 iterations
// The comparison direction should flip for negative steps (i > 0 / j >= 1),
// or descending ranges should be rejected with a diagnostic.
pipeline RangeDescendingNeverRuns {
    attributes {
        position: float3
    }

    pass "Main" {
        use attributes { position }

        vertex {
            float sum = 0.0;

            // Should accumulate 8+6+4+2 = 20, currently accumulates 0
            for (i in 8..0 by -2) {
                sum += float(i);
            }

            // Should accumulate 4+3+2+1 = 10, currently accumulates 0
            for (j in 4..=1 by -1) {
                sum += float(j);
            }

            output.position = float4(attributes.position, sum);
        }
    }
}
