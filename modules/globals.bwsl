// ============================================
// Global Shader Types and Constants
// ============================================
module Globals {

import Math
import PostFX

// ============================================
// Constants
// ============================================
const int MAX_LIGHTS = 16;
const int MAX_CASCADES = 4;
const int MAX_BONES = 128;

// ============================================
// Light Types Enum
// ============================================
enum LightType : int {
    Point = 0,
    Directional = 1,
    Line = 2,
    Spot = 3,
    Probe = 4,
    Area = 5
}

// ============================================
// Vertex Attribute Flags (Bitmask Enum)
// ============================================
enum VertexAttribute : uint {
    Position    = 0b00000001,
    Normal      = 0b00000010,
    TexCoord    = 0b00000100,
    Color       = 0b00001000,
    Tangent     = 0b00010000,
    Bitangent   = 0b00100000,
    BoneIndices = 0b01000000,
    BoneWeights = 0b10000000,
    
    // Check if a specific attribute is present
    eval has :: (self, VertexAttribute flag) -> bool {
        return (self & flag) != 0;
    }
    
    // Count how many attributes are set
    eval count :: (self) -> int {
        int c = 0;
        eval if (self & Position) { c++; }
        eval if (self & Normal) { c++; }
        eval if (self & TexCoord) { c++; }
        eval if (self & Color) { c++; }
        eval if (self & Tangent) { c++; }
        eval if (self & Bitangent) { c++; }
        eval if (self & BoneIndices) { c++; }
        eval if (self & BoneWeights) { c++; }
        return c;
    }
    
    // Check if skinning data is available
    eval hasSkinning :: (self) -> bool {
        return (self & BoneIndices) != 0 && (self & BoneWeights) != 0;
    }
    
    // Check if tangent space is complete
    eval hasTangentSpace :: (self) -> bool {
        return (self & Normal) != 0 && (self & Tangent) != 0 && (self & Bitangent) != 0;
    }
}

// ============================================
// Core Structures
// ============================================

struct CameraUniforms {
    mat4 viewMatrix;
    mat4 projectionMatrix;
    float4 cameraPosition;
};

struct MeshDescriptor {
    VertexAttribute attributeFlags;
    uint[3] _padding;
    uint numVertices;
    uint numIndices;
    uint indexOffset;
    uint positionOffset;
    uint normalOffset;
    uint texCoordOffset;
    uint colorOffset;
    uint tangentOffset;
    uint bitangentOffset;
    uint boneIndicesOffset;
    uint boneWeightsOffset;
};

struct AttributeOffsetInfo {
    uint baseOffset;
    uint stride;
    uint elementCount;
    uint present;
};

struct DrawMetadata {
    uint[2] _pipelineState;
    uint sectionId;
    uint transformIndex;
    uint materialIndex;
    uint _padding;
};

// ============================================
// Material Structure
// ============================================
struct BWEMaterial {
    float4 albedo;
    float roughness;
    float metallic;
    float specular;
    float ambientOcclusion;
    float3 emissiveColor;
    float emissiveIntensity;
    float transparency;
    float refractionIndex;
    float anisotropy;
    float subsurfaceScattering;
    float2 albedoTextureTiling;
    float2 albedoTextureOffset;
    float[2] padding;
};

// ============================================
// Light Data (Structure of Arrays)
// ============================================
struct LightSourcesSoA {
    float3[MAX_LIGHTS] positions;
    float3[MAX_LIGHTS] directions;
    float3[MAX_LIGHTS] colors;
    float[MAX_LIGHTS] intensities;
    float[MAX_LIGHTS] constantAttenuations;
    float[MAX_LIGHTS] linearAttenuations;
    float[MAX_LIGHTS] quadraticAttenuations;
    float[MAX_LIGHTS] innerCutoffs;
    float[MAX_LIGHTS] outerCutoffs;
    float[MAX_LIGHTS] lengths;
    float[MAX_LIGHTS] radii;
    int[MAX_LIGHTS] types;
    int version;
};

// ============================================
// Shadow Structures
// ============================================
struct CascadeData {
    mat4 viewProjMatrix;
    float splitDistance;
    float[3] padding;
};

struct ShadowData {
    CascadeData[MAX_CASCADES] cascades;
    float4 lightDirection;
    uint numCascades;
    uint shadowMapSize;
    float cascadeSplitLambda;
    float shadowBias;
    float shadowSlopeBias;
    float shadowFilterRadius;
    float[2] padding;
};

// ============================================
// Utility Functions
// ============================================

hasAttribute :: (MeshDescriptor desc, VertexAttribute attr) -> bool {
    // Simplified - direct bitwise check instead of method call
    return (desc.attributeFlags & attr) != 0;
}

// ============================================
// Vertex Decompression Functions
// ============================================

decompressPosition_10_10_10 :: (uint packed) -> float3 {
    uint x = packed & 0x3FF;
    uint y = (packed >> 10) & 0x3FF;
    uint z = (packed >> 20) & 0x3FF;
    
    float3 pos;
    pos.x = (float(x) / 1023.0) * 2.0 - 1.0;
    pos.y = (float(y) / 1023.0) * 2.0 - 1.0;
    pos.z = (float(z) / 1023.0) * 2.0 - 1.0;
    
    return pos;
}

decompressOctahedral16 :: (uint packed) -> float3 {
    float2 oct;
    oct.x = float(packed & 0xFF) / 255.0 * 2.0 - 1.0;
    oct.y = float((packed >> 8) & 0xFF) / 255.0 * 2.0 - 1.0;
    
    float3 n = float3(oct.xy, 1.0 - abs(oct.x) - abs(oct.y));
    if (n.z < 0.0) {
        n.xy = (1.0 - abs(n.yx)) * select(float2(-1.0), float2(1.0), n.xy >= 0.0);
    }
    return normalize(n);
}

decompressUV16_16 :: (uint packed) -> float2 {
    return float2(
        float(packed & 0xFFFF) / 65535.0,
        float((packed >> 16) & 0xFFFF) / 65535.0
    );
}

decompressColor8888 :: (uint packed) -> float4 {
    return float4(
        float(packed & 0xFF) / 255.0,
        float((packed >> 8) & 0xFF) / 255.0,
        float((packed >> 16) & 0xFF) / 255.0,
        float((packed >> 24) & 0xFF) / 255.0
    );
}

decompressBoneIndices8888 :: (uint packed) -> int4 {
    return int4(
        int(packed & 0xFF),
        int((packed >> 8) & 0xFF),
        int((packed >> 16) & 0xFF),
        int((packed >> 24) & 0xFF)
    );
}

decompressBoneWeights8888 :: (uint packed) -> float4 {
    return float4(
        float(packed & 0xFF) / 255.0,
        float((packed >> 8) & 0xFF) / 255.0,
        float((packed >> 16) & 0xFF) / 255.0,
        float((packed >> 24) & 0xFF) / 255.0
    );
}

// ============================================
// Color Space Conversion
// ============================================

gammaCorrect :: (float3 color) -> float3 {
    return PostFX::gammaCorrect(color);
}

inverseGammaCorrect :: (float3 color) -> float3 {
    return PostFX::inverseGammaCorrect(color);
}

linearToSRGB :: (float3 color) -> float3 {
    return PostFX::linearToSRGB(color);
}

sRGBToLinear :: (float3 color) -> float3 {
    return PostFX::sRGBToLinear(color);
}

// ============================================
// Tone Mapping
// ============================================

ACESFilm :: (float3 x) -> float3 {
    return PostFX::ACESFilm(x);
}

reinhardToneMap :: (float3 color) -> float3 {
    return PostFX::reinhardToneMap(color);
}

reinhardExtendedToneMap :: (float3 color, float maxWhite) -> float3 {
    return PostFX::reinhardExtendedToneMap(color, maxWhite);
}

}
